---
import Layout from '../layouts/Layout.astro';
import GradientBackground from '../components/GradientBackground.astro';
---

<Layout title="Bank Login - Zelify">
  <main>
    <div class="min-h-screen flex items-center justify-center p-4 bg-gradient-to-br from-gray-50 to-white relative overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-green-500/5"></div>
      <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl border border-gray-100 relative backdrop-blur-sm hover:shadow-blue-500/5 transition-all duration-300">
        <div class="text-center mb-8">
          <div class="mb-6 relative">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-green-500/10 rounded-lg blur-xl"></div>
            <img src="/assets/img/logo.svg" alt="Zelify" class="h-8 mx-auto relative" />
          </div>
          <h1 class="text-2xl font-bold text-gray-800">Bank Portal</h1>
          <p class="text-gray-600 mt-2">Secure access to your banking dashboard</p>
          <div class="flex justify-center gap-2 mt-4">
            <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-xs font-medium">Secure Connection</span>
            <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-xs font-medium">Bank Verified</span>
          </div>
        </div>

        <form class="space-y-6" id="loginForm">
          <div class="space-y-4">
            <div class="relative">
              <label class="block text-gray-700 text-sm font-medium mb-2" for="username">
                Username
              </label>
              <input
                type="text"
                id="username"
                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 pl-10 transition-all duration-200"
                placeholder="Enter your username"
              />
              <i class="eva eva-person-outline absolute left-3 top-[38px] text-gray-400"></i>
            </div>

            <div class="relative">
              <label class="block text-gray-700 text-sm font-medium mb-2" for="password">
                Password
              </label>
              <input
                type="password"
                id="password"
                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 pl-10 pr-10 transition-all duration-200"
                placeholder="Enter your password"
              />
              <i class="eva eva-lock-outline absolute left-3 top-[38px] text-gray-400"></i>
              <button type="button" class="absolute right-3 top-[38px] text-gray-400 hover:text-gray-600">
                <i class="eva eva-eye-outline"></i>
              </button>
            </div>
          </div>

          <div class="flex items-center justify-between text-sm">
            <label class="flex items-center text-gray-600">
              <input type="checkbox" class="mr-2 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              Remember me
            </label>
            <a href="#" class="text-blue-600 hover:text-blue-700">Forgot password?</a>
          </div>

          <button
            type="submit"
            class="w-full py-3 px-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg font-bold hover:from-blue-700 hover:to-blue-800 transition-all duration-300 flex items-center justify-center gap-2 shadow-lg shadow-blue-500/30 hover:shadow-blue-500/40"
          >
            <i class="eva eva-lock-outline"></i>
            Secure Login
          </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center">
          <p class="text-gray-500 text-sm">
            Need assistance? <a href="#" class="text-blue-600 hover:underline">Contact Support</a>
          </p>
        </div>

        <div class="mt-8 text-center">
          <div class="text-gray-500 text-xs">
            Protected by industry-leading security protocols
          </div>
          <div class="flex justify-center gap-4 mt-4">
            <i class="eva eva-shield-outline text-blue-600/80 text-xl"></i>
            <i class="eva eva-lock-outline text-blue-600/80 text-xl"></i>
            <i class="eva eva-activity-outline text-blue-600/80 text-xl"></i>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('loginForm');
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const username = (document.getElementById('username') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    
    // Aquí iría la lógica de autenticación
    console.log('Login attempt:', { username, password });
  });
</script>

<style>
  .bg-grid-pattern {
    background-image: linear-gradient(to right, rgba(0,0,0,0.1) 1px, transparent 1px),
                      linear-gradient(to bottom, rgba(0,0,0,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  input::placeholder {
    color: rgba(100, 116, 139, 0.5);
  }

  input[type="checkbox"] {
    accent-color: #3983ED;
  }

  input:focus {
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }
</style> 