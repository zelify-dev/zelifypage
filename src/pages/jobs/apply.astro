---
import Layout from '../../layouts/Layout.astro';
import BackButton from '../../components/BackButton.astro';

const position = Astro.url.searchParams.get('position');

// Questions from CSV translated to English and converted to multiple choice
const questions = [
  {
    id: 'experience',
    question: 'Briefly describe your experience level with microservices and fintech projects',
    options: [
      'No experience with microservices or fintech',
      '1-2 years of experience with either microservices or fintech',
      '2-4 years of experience with both microservices and fintech',
      '4+ years of experience with both microservices and fintech'
    ]
  },
  {
    id: 'team_size',
    question: 'What is the largest team size you have worked with or led?',
    options: [
      'Less than 5 people',
      '5-10 people',
      '10-20 people',
      'More than 20 people'
    ]
  },
  {
    id: 'neobanking',
    question: 'What is your knowledge level of neobanking platforms?',
    options: [
      'Basic understanding',
      'Worked with neobanking platforms as a user',
      'Developed features for neobanking platforms',
      'Extensive experience building neobanking solutions'
    ]
  },
  {
    id: 'nestjs',
    question: 'Rate your NestJS knowledge',
    options: [
      'No experience',
      'Basic knowledge',
      'Intermediate knowledge',
      'Advanced knowledge'
    ]
  },
  {
    id: 'kafka',
    question: 'Rate your Apache Kafka knowledge',
    options: [
      'No experience',
      'Basic knowledge',
      'Intermediate knowledge',
      'Advanced knowledge'
    ]
  },
  {
    id: 'api_integration',
    question: 'What is your experience with third-party API integrations?',
    options: [
      'No experience',
      'Basic REST API integrations',
      'Complex API integrations including SOAP and REST',
      'Advanced integrations with multiple security protocols'
    ]
  },
  {
    id: 'docker',
    question: 'What is your experience with Docker containerization?',
    options: [
      'No experience',
      'Basic container usage',
      'Container creation and optimization',
      'Advanced containerization and orchestration'
    ]
  },
  {
    id: 'aws_ecs',
    question: 'What is your experience with AWS ECS?',
    options: [
      'No experience',
      'Basic understanding',
      'Deployed and managed containers',
      'Advanced cluster management and optimization'
    ]
  },
  {
    id: 'availability',
    question: 'What is your availability to start?',
    options: [
      'Immediately',
      'In 2 weeks',
      'In 1 month',
      'More than 1 month'
    ]
  }
];
---

<Layout title="Apply | Zelify">
  <div class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl font-bold text-gray-900 mb-8 text-center">Application Form</h1>
      
      <form id="applicationForm" class="bg-white rounded-xl shadow-sm p-8" enctype="multipart/form-data">
        <!-- Personal Information -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Personal Information</h2>
          <div class="grid gap-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                <input type="text" name="firstName" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                <input type="text" name="lastName" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input type="email" name="email" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
                <input type="tel" name="phone" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>
            </div>
            <!-- CV Upload -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">CV/Resume *</label>
              <input
                type="file"
                name="cv"
                accept=".pdf,.doc,.docx"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              />
              <p class="mt-1 text-sm text-gray-500">Accepted formats: PDF, DOC, DOCX (Max size: 5MB)</p>
            </div>
          </div>
        </section>

        <!-- Questions -->
        <section class="space-y-8">
          {questions.map((q, index) => (
            <div class="border-t pt-6">
              <label class="block text-sm font-medium text-gray-900 mb-3">{q.question} *</label>
              <div class="space-y-3">
                {q.options.map((option, optIndex) => (
                  <div class="flex items-center">
                    <input
                      type="radio"
                      name={q.id}
                      value={option}
                      required
                      class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300"
                    />
                    <label class="ml-3 text-sm text-gray-700">{option}</label>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>

        <!-- Submit Button -->
        <div class="mt-8 flex flex-col items-center gap-4">
          <button
            type="submit"
            id="submitButton"
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-300 shadow-sm hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span>Submit Application</span>
            <svg class="hidden animate-spin ml-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
          <p id="fileError" class="text-red-600 text-sm hidden">CV file size must be less than 5MB</p>
        </div>
      </form>

      <!-- Success Message (hidden by default) -->
      <div id="successMessage" class="hidden mt-8 p-4 bg-green-100 rounded-lg">
        <p class="text-green-700 text-center">
          Thank you for your application! We will review it and get back to you soon.
        </p>
      </div>

      <!-- Error Message (hidden by default) -->
      <div id="errorMessage" class="hidden mt-8 p-4 bg-red-100 rounded-lg">
        <p class="text-red-700 text-center">
          There was an error submitting your application. Please try again.
        </p>
      </div>
    </div>
  </div>

  <BackButton href={`/jobs/${position}`} />
</Layout>

<script>
  const form = document.getElementById('applicationForm') as HTMLFormElement;
  const submitButton = document.getElementById('submitButton') as HTMLButtonElement;
  const submitSpinner = submitButton.querySelector('svg') as SVGElement;
  const submitText = submitButton.querySelector('span') as HTMLSpanElement;
  const successMessage = document.getElementById('successMessage');
  const errorMessage = document.getElementById('errorMessage');
  const fileError = document.getElementById('fileError');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Reset messages
    successMessage?.classList.add('hidden');
    errorMessage?.classList.add('hidden');
    fileError?.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    const cvFile = formData.get('cv') as File;

    // Validate file size (5MB max)
    if (cvFile.size > 5 * 1024 * 1024) {
      fileError?.classList.remove('hidden');
      return;
    }

    try {
      // Show loading state
      submitButton.disabled = true;
      submitSpinner.classList.remove('hidden');
      submitText.textContent = 'Submitting...';

      const response = await fetch('/api/submit-application', {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        form.style.display = 'none';
        successMessage?.classList.remove('hidden');
        window.scrollTo(0, 0);
      } else {
        const error = await response.json();
        errorMessage?.classList.remove('hidden');
        console.error('Submission error:', error);
      }
    } catch (error) {
      console.error('Error submitting form:', error);
      errorMessage?.classList.remove('hidden');
    } finally {
      // Reset button state
      submitButton.disabled = false;
      submitSpinner.classList.add('hidden');
      submitText.textContent = 'Submit Application';
    }
  });

  // Reset error message when file input changes
  const fileInput = form?.querySelector('input[type="file"]');
  fileInput?.addEventListener('change', () => {
    fileError?.classList.add('hidden');
  });
</script>

<style>
  /* Custom radio button styles */
  input[type="radio"] {
    @apply cursor-pointer;
  }

  input[type="radio"]:checked + label {
    @apply text-blue-600 font-medium;
  }

  /* File input styles */
  input[type="file"] {
    @apply file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium
    file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer;
  }

  /* Loading spinner animation */
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style> 