---
import Layout from '../../layouts/Layout.astro';
import BackButton from '../../components/BackButton.astro';

const currentPath = Astro.url.pathname;
const jobId = currentPath.split('/').pop();
---

<Layout title="Semi Senior Software Engineer | Zelify">
  <div class="min-h-screen bg-gray-50">
    <!-- Banner -->
    <div class="relative h-64 bg-gradient-to-r from-blue-600 to-blue-800">
      <div class="absolute inset-0 bg-black/20"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <div class="text-center">
          <h1 class="text-4xl font-bold text-white mb-4">Semi Senior Software Engineer</h1>
          <div class="flex items-center justify-center gap-4 text-sm text-white/90">
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Remote
            </span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Full-time
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="bg-white rounded-xl shadow-sm p-8">
        <!-- About Us -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">About Us</h2>
          <p class="text-gray-600 mb-6">
            Founded in 2018, we're on a mission to combat complexity and empower people by reinventing financial services and facilitating international transfers in Latin America. Zelify transforms banking for personal and business users, enabling you to send, split, or gift money instantly, without complications or waiting. With fluid transactions as easy as sending a message, you have the power to connect, pay, and share instantly.
          </p>
        </section>

        <!-- Our Work Model -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Work Model</h2>
          <p class="text-gray-600 mb-6">
            At Zelify, we create multifunctional, diverse, and inclusive teams, attracting the best talent to develop revolutionary technology. Our engineering team uses advanced technologies and agile methodologies that allow rapid adaptation to market needs. Our hybrid model provides independence and promotes professional responsibility to meet goals aligned with our global objectives. Our Engineering team transforms technology into high-impact financial solutions.
          </p>
        </section>

        <!-- Our Culture -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Culture</h2>
          <p class="text-gray-600 mb-6">
            At Zelify, we've created an international neo-banking platform centered on the user, constantly challenging the limits of technology. Our promise is to connect payments and unite people, empowering our users to pay, share, and connect instantly. We cultivate a culture of professional growth, innovation, and entrepreneurship, promoting autonomy and responsibility where engineers own their projects from conception to implementation.
          </p>
        </section>

        <!-- Technical Requirements -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Technical Requirements</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Experience with horizontally scalable microservices (NodeJS, NestJS, PostgreSQL, WebSocket, Java v11, Spring Boot)</li>
            <li>Knowledge of service communication using Kafka</li>
            <li>Deep knowledge of Docker</li>
            <li>Advanced knowledge in national and foreign bank integration services through REST API and the use of an API Gateway.</li>
            <li>Continuous integration and deployment in AWS</li>
            <li>Experience with AWS cloud technologies, especially AWS RDS and AWS ECS</li>
            <li>At least two years of experience in Backend services development and general Software development</li>
          </ul>
        </section>

        <!-- Integrations -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Integrations</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Comprehensive experience in REST API integrations and microservices architecture</li>
            <li>Previous experience in banking integrations, including financial services such as transactions, account creation, and core banking systems</li>
            <li>Implementation of secure integration mechanisms using API Gateway, JWT, and API keys</li>
            <li>Proficiency in Postman collections and API documentation best practices</li>
          </ul>
        </section>

        <!-- Role Expectations -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">What We Expect</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Focus on backend applications oriented to continuous creation and delivery of microservices</li>
            <li>Plan and execute complete functions, collaborating with peers while planning future work</li>
            <li>Write, test, instrument, document, and maintain code</li>
            <li>Request clear code reviews to integrate changes into project development</li>
            <li>Report incidents early and request support only when necessary</li>
            <li>Experience in teams that define asynchronous integrations using event-based architectures</li>
            <li>Practical knowledge of agile software development methodologies</li>
            <li>Able to carry out multiple integrations.</li>
          </ul>
        </section>

        <!-- Nice to Have -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Nice to Have</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Infrastructure management with Terraform and Ansible</li>
            <li>Practical experience in automation flow for CI/CD with Jenkins, Shell, AWS CLI, Nexus, Docker, Testing, SSL, and Nginx</li>
            <li>Analysis and design of distributed architecture for transactional applications using Traefik and ELK</li>
            <li>Knowledge of non-relational databases</li>
          </ul>
        </section>

        <!-- Apply Button -->
        <div class="flex justify-center">
          <a
            href={`/jobs/apply?position=${jobId}`}
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-300 shadow-sm hover:shadow-md"
          >
            Apply for this position
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <BackButton href="/jobs" />
</Layout>

<style>
  /* Smooth transitions */
  .transition-colors {
    transition-property: background-color, border-color, color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }
</style> 