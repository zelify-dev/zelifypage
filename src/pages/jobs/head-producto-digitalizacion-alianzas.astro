---
import Layout from '../../layouts/Layout.astro';
import BackButton from '../../components/BackButton.astro';

const currentPath = Astro.url.pathname;
const jobId = currentPath.split('/').pop();
---

<Layout title="Head of Product, Digitalization and Alliances | Zelify">
  <div class="min-h-screen bg-gray-50">
    <!-- Banner -->
    <div class="relative h-64 bg-gradient-to-r from-blue-600 to-blue-800">
      <div class="absolute inset-0 bg-black/20"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <div class="text-center">
          <h1 class="text-4xl font-bold text-white mb-4">Head of Product, Digitalization and Alliances</h1>
          <div class="flex items-center justify-center gap-4 text-sm text-white/90">
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Latam
            </span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Full-time / Part-time
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="bg-white rounded-xl shadow-sm p-8">
        <!-- About Zelify -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">About Zelify</h2>
          <p class="text-gray-600 mb-6">
            Founded in 2018, we're on a mission to combat complexity and empower people by reinventing financial services and facilitating international transfers in Latin America. Zelify transforms banking for personal and business users, enabling you to send, split, or gift money instantly, without complications or waiting.
          </p>
          <p class="text-gray-600 mb-6">
            Zelify is the neo-banking platform of Zwippetech Inc. that facilitates the banking of users and businesses through cutting-edge technology, eliminating transactional borders and allowing individuals and companies to open 100% digital savings accounts and perform international transfers efficiently, transparently, and securely.
          </p>
        </section>

        <!-- Our Work Model -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Work Model</h2>
          <p class="text-gray-600 mb-6">
            At Zwippetech, we create multifunctional, diverse, and inclusive teams, attracting the best talent to develop revolutionary technology. To achieve this, our engineering team uses advanced technologies and agile methodologies that allow rapid adaptation to market needs.
          </p>
          <p class="text-gray-600 mb-6">
            Our hybrid model provides independence and promotes professional responsibility to meet goals aligned with our global objectives. Our Engineering team transforms technology into high-impact financial solutions.
          </p>
        </section>

        <!-- Our Culture -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Culture</h2>
          <p class="text-gray-600 mb-6">
            At Zelify, we've created an international neo-banking platform centered on the user, constantly challenging the limits of technology. Our promise is to connect payments and unite people, empowering our users to pay, share, and connect instantly.
          </p>
          <p class="text-gray-600 mb-6">
            We cultivate a culture of professional growth, innovation, and entrepreneurship. We promote a culture of autonomy and responsibility, where engineers own their projects from conception to implementation.
          </p>
        </section>

        <!-- About the Role -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">About the Role: Head of Product, Digitalization and Alliances</h2>
          <p class="text-gray-600 mb-6">
            As Head of Product, Digitalization and Alliances, you will have the following responsibilities:
          </p>
          <ul class="list-disc list-inside text-gray-600 space-y-3 mb-6">
            <li>Product Strategy and Roadmap</li>
            <li>Financial Institution Relationship Management</li>
            <li>Internal Coordination for Banking Integrations</li>
            <li>Product Lifecycle Management</li>
            <li>Business Expansion and Development</li>
            <li>Communication and PR</li>
          </ul>
        </section>

        <!-- Role Objectives -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Role Objectives (KPIs)</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Growth of active users and transaction volume in target markets</li>
            <li>Number of new banking alliances integrated</li>
            <li>Improvement in activation and retention rates of launched products</li>
            <li>Average integration time with new financial partners</li>
            <li>SLA/SLO compliance in banking service integrations</li>
            <li>Market penetration and revenue generation from new implemented products</li>
            <li>Product NPS and customer experience</li>
          </ul>
        </section>

        <!-- Expected Contribution -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Expected Contribution of the Position</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Contribute your experience in payment methods, strategic alliances, and financial product development to lead Zelify's priority projects in Colombia and other key markets.</li>
            <li>Implement commercial and product strategies that generate value and position Zelify as a leader in financial innovation and digital banking.</li>
            <li>Optimize onboarding processes, product launches, and user experience.</li>
            <li>Contribute to strengthening current alliances and opening new relationships that facilitate Zelify's expansion to new markets.</li>
          </ul>
        </section>

        <!-- Economic Proposal -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Economic Proposal and Engagement</h2>
          <p class="text-gray-600 mb-6">
            We propose the incorporation under the Head of Product, Digitalization and Alliances scheme with a participation scheme that includes:
          </p>
          
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Equity Participation:</h3>
          <p class="text-gray-600 mb-4">
            A 1% in ordinary shares of Zwippetech S.A.S Colombia will be granted with 12-month vesting and 3-month cliff, in line with Colombian market standards for high-impact executive roles in technology startups.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Performance Bonus:</h3>
          <p class="text-gray-600 mb-4">
            An additional 0.5% in ordinary shares will be granted subject to the achievement of strategic KPIs defined during the first 180 days of engagement.
          </p>
        </section>

        <!-- Benefits -->
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Benefits (Perks)</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>Health insurance</li>
            <li>Annual performance-based bonuses</li>
            <li>Monthly technology tool allocation for your work</li>
            <li>Additional benefits according to seniority level</li>
            <li>Hybrid work with flexibility to adapt to specific in-person client needs</li>
            <li>One course on Udemy or Platzi</li>
            <li>Year-end bonus as additional benefit</li>
            <li>Monthly discount coupon for transfers in our app</li>
            <li>Free dress code</li>
            <li>Birthday day off</li>
            <li>Computer gift after two years in the company</li>
            <li>0 km car after 5 years of seniority</li>
          </ul>
        </section>

        <!-- Apply Button -->
        <div class="flex justify-center">
          <a
            href={`/jobs/apply?position=${jobId}`}
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-300 shadow-sm hover:shadow-md"
          >
            Apply for this position
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <BackButton href="/jobs" />
</Layout>

<style>
  /* Smooth transitions */
  .transition-colors {
    transition-property: background-color, border-color, color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }
</style>
