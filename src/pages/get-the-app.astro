---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Zelify App">
  <div class="min-h-screen bg-white flex flex-col items-center justify-center p-4">
    
    <h1 class="text-6xl font-bold text-gray-900 mb-4 text-center">
      UNLOCK BORDERLESS BANKING
    </h1>
    
    <p class="text-2xl text-gray-600 text-center max-w-2xl mb-4">
      Your all-in-one digital payment solution.
    </p>

    <p class="text-gray-500 text-center max-w-2xl">
      Global ATM access • Tap & pay worldwide • Secure online shopping • International transfers • Real-time tracking • Smart card management
    </p>

    <script>
      // Intenta detectar el país del usuario
      fetch('https://ipapi.co/json/')
        .then(response => response.json())
        .then(data => {
          const country = data.country_name;
          const heading = document.querySelector('h1');
          if (heading) heading.textContent = `Coming soon to ${country}`;
        })
        .catch(() => {
          // Si falla, mantiene el mensaje genérico
          console.log('Could not detect country');
        });
    </script>
  </div>
</Layout> 