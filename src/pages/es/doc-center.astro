---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import BackButton from '../../components/BackButton.astro';

// Leer el contenido de los archivos markdown
const policyPath = path.join(process.cwd(), 'src/content/policy.md');
const policyContent = fs.readFileSync(policyPath, 'utf-8');
const policyHtml = marked.parse(policyContent);

// Leer el contenido del archivo license-agreement.md
const licensePath = path.join(process.cwd(), 'src/content/license-agreement.md');
const licenseContent = fs.readFileSync(licensePath, 'utf-8');
const licenseHtml = marked.parse(licenseContent);
---

<Layout title="Centro de Documentación | Zelify">
  <BackButton />
  <main class="container mx-auto px-4 py-16">
    <!-- Botón Volver Arriba -->
    <button
      id="scrollToTop"
      class="fixed bottom-8 right-8 bg-blue-600 text-white p-3 rounded-full shadow-lg opacity-0 transition-opacity duration-300 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
      aria-label="Volver arriba"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"
        />
      </svg>
    </button>

    <h1 class="text-4xl font-bold text-center mb-4">Centro de Documentación</h1>
    <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
      Documentación completa sobre nuestras políticas, términos y medidas de protección de datos.
    </p>

    <div class="max-w-4xl mx-auto">
      <div class="mb-4 border-b border-gray-200">
        <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="docTabs" role="tablist">
          <li class="mr-2" role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button active" id="privacy-tab" data-target="privacy">Política de Privacidad</button>
          </li>
          <li class="mr-2" role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" id="terms-tab" data-target="terms">Política de Prevención de Lavado de Dinero</button>
          </li>
          <li role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" id="data-tab" data-target="data">Acuerdo de Licencia</button>
          </li>
        </ul>
      </div>

      <div id="tabContent" class="bg-white rounded-lg shadow-sm border border-gray-100">
        <div class="tab-panel active p-8" id="privacy">
          <h2 class="text-3xl font-bold mb-6">Política de Privacidad</h2>
          <div class="prose max-w-none">
            <p class="text-gray-600 mb-8">Última actualización: 20 de enero de 2025</p>
            
            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Propósito</h3>
              <p class="mb-4">
                Esta Política de Privacidad de Datos Personales (en adelante, la "Política de Privacidad") tiene como objetivo informar cómo Zwippetech Inc. (en adelante, "Zwippetech"), una entidad legal constituida bajo las leyes de Delaware, Estados Unidos, procesa los datos personales recopilados a través de su Plataforma Zelify (en adelante, la "Plataforma").
              </p>
              <p class="mb-4">
                Estos datos se recopilan a través del uso de la Plataforma, el llenado de formularios virtuales y a través de varios espacios en la Plataforma diseñados para ingresar datos personales virtuales.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Base Legal</h3>
              <p class="mb-4">
                Esta Política de Privacidad se rige por la ley de EE. UU., en particular:
              </p>
              <ul class="list-disc pl-6 mb-4 space-y-2">
                <li>Ley Gramm-Leach-Bliley (GLBA)</li>
                <li>Ley del Derecho a la Privacidad Financiera (RFPA)</li>
                <li>Ley de Privacidad del Consumidor de California (CCPA)</li>
                <li>Reglamento General de Protección de Datos (GDPR)</li>
                <li>Otras regulaciones secundarias aplicables</li>
              </ul>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Período de Retención</h3>
              <p class="mb-4">
                Los datos personales proporcionados por el Titular de los Datos se conservarán durante el tiempo necesario para cumplir con el propósito para el que fueron recopilados y/o hasta que el Titular de los Datos revoque su consentimiento, de acuerdo con las regulaciones de la Ley y las leyes aplicables.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Bases de Datos Personales</h3>
              <p class="mb-4">
                Los datos personales proporcionados se almacenarán en la base de datos personal denominada "USUARIOS", debidamente registrada en el Registro Nacional de Protección de Datos Personales.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Finalidad del Tratamiento</h3>
              <p class="mb-4">
                A través de un formulario virtual alojado en la Plataforma, Zwippetech recopila datos personales como nombres, apellidos, números de teléfono, correos electrónicos, direcciones y números de seguridad social, principalmente para cumplir con las regulaciones para los procesos de incorporación de la plataforma.
              </p>
            </section>

            <!-- Transferencia y Destinatarios -->
            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Transferencia y Destinatarios</h3>
              <p class="mb-4">
                Se informa al Titular de los Datos que sus datos personales se comparten con terceros, según se detalla en la Plataforma.
              </p>
              
              <div class="overflow-x-auto">
                <table class="min-w-full border border-gray-200 mb-4">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Destinatario
                      </th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        País de Ubicación de Servidores
                      </th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Propósito
                      </th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        Amazon Web Services
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        Estados Unidos – Virginia
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        Infraestructura en la nube y almacenamiento de base de datos
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Medidas de Seguridad</h3>
              <p class="mb-4">
                Zwippetech adopta las medidas de seguridad necesarias para garantizar la protección de la información del Titular de los Datos, evitando su alteración, pérdida, acceso o tratamiento no autorizado, considerando la naturaleza de la información y los riesgos a los que está expuesta.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Comunicaciones y Tratamientos Posteriores</h3>
              <p class="mb-4">
                Zwippetech se compromete a no divulgar ni compartir los datos personales proporcionados por el Titular de los Datos sin su consentimiento válido, excepto en casos específicos como solicitudes de información de autoridades administrativas o judiciales en el ejercicio de sus funciones y dentro del ámbito de sus competencias según la Ley.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Uso de Cookies en la Plataforma</h3>
              <p class="mb-4">
                La Plataforma no utiliza cookies y, por lo tanto, no se realiza ningún tratamiento de datos personales de esa manera.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Portabilidad de Datos Personales</h3>
              <p class="mb-4">
                A solicitud explícita del Titular de los Datos, Zwippetech puede devolver los datos personales recopilados de ellos en un formato compatible, actualizado, estructurado, común, interoperable y legible por máquina, preservando sus características o entregarlos a otro controlador definido por el Titular de los Datos.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Revocación del Consentimiento</h3>
              <p class="mb-4">
                El Titular de los Datos puede revocar la autorización y consentimiento otorgado a Zwippetech para el tratamiento de sus datos personales mediante una solicitud por escrito al correo electrónico mencionado anteriormente.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Modificaciones a la Política de Privacidad</h3>
              <p class="mb-4">
                Zwippetech se reserva expresamente el derecho de modificar, actualizar o complementar esta Política de Privacidad en cualquier momento. Cualquier modificación será comunicada inmediatamente a través de la Plataforma.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Legislación Aplicable y Resolución de Conflictos</h3>
              <p class="mb-4">
                Los términos de la Política de Privacidad se rigen e interpretan de acuerdo con las leyes de los Estados Unidos, sujetos a la jurisdicción de Delaware y las Autoridades Competentes para la Protección de Datos Personales.
              </p>
            </section>

            <footer class="text-sm text-gray-600 border-t pt-8">
              <p>Copyright © 2025 Zwippetech, Inc. Todos los derechos reservados.</p>
            </footer>
          </div>
        </div>

        <div class="tab-panel hidden p-8" id="terms">
          <div class="prose max-w-none">
            <div set:html={policyHtml} />
          </div>
        </div>

        <div class="tab-panel hidden p-8" id="data">
          <div class="prose max-w-none">
            <div set:html={licenseHtml} />
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Remover clase activa de todos los botones y paneles
      tabButtons.forEach(btn => btn.classList.remove('active'));
      tabPanels.forEach(panel => panel.classList.add('hidden'));

      // Agregar clase activa al botón clickeado y mostrar el panel correspondiente
      button.classList.add('active');
      const targetPanel = document.getElementById(button.dataset.target);
      targetPanel.classList.remove('hidden');
    });
  });

  // Función para manejar el botón de volver arriba
  document.addEventListener('DOMContentLoaded', () => {
    const scrollToTopButton = document.getElementById('scrollToTop');
    
    // Mostrar/ocultar el botón basado en la posición del scroll
    const toggleScrollButton = () => {
      if (window.scrollY > 500) {
        scrollToTopButton?.classList.remove('opacity-0');
        scrollToTopButton?.classList.add('opacity-100');
      } else {
        scrollToTopButton?.classList.remove('opacity-100');
        scrollToTopButton?.classList.add('opacity-0');
      }
    };
    
    // Función para volver arriba suavemente
    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    };
    
    // Event listeners
    window.addEventListener('scroll', toggleScrollButton);
    scrollToTopButton?.addEventListener('click', scrollToTop);
  });
</script>

<style>
  .tab-button.active {
    @apply text-blue-600 border-blue-600;
  }
  .tab-panel {
    @apply p-4;
  }
  :global(.prose h1) {
    @apply text-3xl font-bold mb-6;
  }
  :global(.prose h2) {
    @apply text-2xl font-semibold mb-4 mt-8;
  }
  :global(.prose h3) {
    @apply text-xl font-semibold mb-3 mt-6;
  }
  :global(.prose p) {
    @apply mb-4 text-gray-600;
  }
  :global(.prose ul) {
    @apply list-disc pl-6 mb-4 space-y-2;
  }
  :global(.prose ol) {
    @apply list-decimal pl-6 mb-4 space-y-2;
  }
  :global(.prose table) {
    @apply min-w-full border border-gray-200 mb-4;
  }
  :global(.prose th) {
    @apply px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase bg-gray-50;
  }
  :global(.prose td) {
    @apply px-6 py-4 text-sm text-gray-900 border-t border-gray-200;
  }
</style> 