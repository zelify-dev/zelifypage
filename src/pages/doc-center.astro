---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import BackButton from '../components/BackButton.astro';

// Leer el contenido de los archivos markdown
const policyPath = path.join(process.cwd(), 'src/content/policy.md');
const policyContent = fs.readFileSync(policyPath, 'utf-8');
const policyHtml = marked.parse(policyContent);

// Leer el contenido del archivo license-agreement.md
const licensePath = path.join(process.cwd(), 'src/content/license-agreement.md');
const licenseContent = fs.readFileSync(licensePath, 'utf-8');
const licenseHtml = marked.parse(licenseContent);
---

<Layout title="Zelify Docs | Zelify">
  <BackButton />
  <main class="container mx-auto px-4 py-16">
    <!-- Botón Volver Arriba -->
    <button
      id="scrollToTop"
      class="fixed bottom-8 right-8 bg-blue-600 text-white p-3 rounded-full shadow-lg opacity-0 transition-opacity duration-300 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
      aria-label="Volver arriba"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"
        />
      </svg>
    </button>

    <h1 class="text-4xl font-bold text-center mb-4">Zelify Docs</h1>
    <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
      Comprehensive documentation about our policies, terms, and data protection measures.
    </p>

    <div class="max-w-4xl mx-auto">
      <div class="mb-4 border-b border-gray-200">
        <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="docTabs" role="tablist">
          <li class="mr-2" role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button active" id="privacy-tab" data-target="privacy">Privacy Policy</button>
          </li>
          <li class="mr-2" role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" id="terms-tab" data-target="terms">Policy On The Prevention Of Money Laundering</button>
          </li>
          <li role="presentation">
            <button class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300 tab-button" id="data-tab" data-target="data">License Agreement</button>
          </li>
        </ul>
      </div>

      <div id="tabContent" class="bg-white rounded-lg shadow-sm border border-gray-100">
        <div class="tab-panel active p-8" id="privacy">
          <h2 class="text-3xl font-bold mb-6">Privacy Policy</h2>
          <div class="prose max-w-none">
            <p class="text-gray-600 mb-8">Last updated: January 20, 2025</p>
            
            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Purpose</h3>
              <p class="mb-4">
                This Personal Data Privacy Policy (hereinafter, the "Privacy Policy") aims to inform how Zwippetech Inc. (hereinafter, "Zwippetech"), a legal entity incorporated under the laws of Delaware, United States, processes personal data collected through its Zelify Platform (hereinafter, the "Platform").
              </p>
              <p class="mb-4">
                This data is collected through the usage of the Platform, filling out virtual forms, and through various spaces on the Platform designed for entering virtual personal data.
              </p>
              <p class="mb-4">
                For the purposes of this policy, we will refer to the "Data Subject" as the person whose data will be collected and processed in accordance with the terms set forth in the Privacy Policy. Only personal data for which proper consent has been obtained is processed unless exceptions established in the Data Protection Act (the "Act") apply.
              </p>
              <p class="mb-4">
                The processing of personal data derived from this Privacy Policy is legitimate and lawful due to obtaining the consent of the Data Subject, and its origin comes directly from the Data Subject.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Legal Basis</h3>
              <p class="mb-4">
                This Privacy Policy is governed by U.S. law, in particular:
              </p>
              <ul class="list-disc pl-6 mb-4 space-y-2">
                <li>Gramm-Leach-Bliley Act (GLBA)</li>
                <li>Right to Financial Privacy Act (RFPA)</li>
                <li>California Consumer Privacy Act (CCPA)</li>
                <li>General Data Protection Regulation (GDPR)</li>
                <li>Other applicable secondary regulations</li>
              </ul>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Retention Period</h3>
              <p class="mb-4">
                Personal data provided by the Data Subject will be retained as long as necessary to fulfill the purpose for which it was collected and/or until the Data Subject revokes their consent, in accordance with the regulations of the Act and applicable laws.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Personal Databases</h3>
              <p class="mb-4">
                The provided personal data will be stored in the personal database called "USERS," duly registered in the National Registry of Personal Data Protection.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Purpose of Processing</h3>
              <p class="mb-4">
                Through a virtual form hosted on the Platform, Zwippetech collects personal data such as names, surnames, phone numbers, emails, addresses, and social security numbers, primarily to comply with regulations for the onboarding processes of the platform.
              </p>
              <p class="mb-4">
                This personal data provided by the Data Subject is necessary to provide online transactional services on the Zwippetech platform. Zwippetech may conduct systematic evaluations of personal aspects and behaviors of its users within the Platform, such as profile creation, transactional trends and habits, ensuring a properly disassociated or at least anonymized treatment of this data, always adhering to the security measures, principles, and limitations established by the Law.
              </p>
              <p class="mb-4">
                If the Data Subject does not provide this data or provides incorrect or inaccurate data, Zwippetech will not be able to fulfill the aforementioned purpose, and it will impact the quality and manner of execution of the services provided by Zwippetech.
              </p>
              <p class="mb-4">
                Additionally, with the valid consent of the Data Subject, Zwippetech may contact them through [phone calls, SMS, emails, or other equivalent means] to send notifications about platform usage and general information. If the Data Subject does not accept the additional processing of their personal data, it will not affect access and use of the Platform and the services provided therein.
              </p>
            </section>

            <!-- Transfer and Recipients Section -->
            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Transfer and Recipients</h3>
              <p class="mb-4">
                The Data Subject is informed that their personal data is shared with third parties, as detailed on the Platform.
              </p>
              
              <div class="overflow-x-auto">
                <table class="min-w-full border border-gray-200 mb-4">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Destinatary
                      </th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Country Servers Are Based
                      </th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Purpose
                      </th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        Amazon Web Services
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        United States – Virginia
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        Cloud infrastructure and database storage
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Security Measures</h3>
              <p class="mb-4">
                Zwippetech adopts the necessary security measures to ensure the protection of the Data Subject's information, preventing its alteration, loss, unauthorized access, or processing, considering the nature of the information and the risks to which it is exposed. To protect the personal data of the Data Subject, Zwippetech strictly complies with the provisions of the Law and its Regulation.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Communications and Subsequent Treatments</h3>
              <p class="mb-4">
                Zwippetech commits not to disclose or share the personal data provided by the Data Subject without their valid consent, except in specific cases such as requests for information from administrative or judicial authorities in the exercise of their functions and within the scope of their competencies under the Law.
              </p>
              <p class="mb-4">
                The Data Subject can revoke their consent for such communications at any time, without the need for any justification.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Use of Cookies on the Platform</h3>
              <p class="mb-4">
                The Platform does not use cookies, and therefore, no personal data processing is carried out in that manner.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Portability of Personal Data</h3>
              <p class="mb-4">
                Upon explicit request from the Data Subject, Zwippetech may return the personal data collected from them in a compatible, updated, structured, common, interoperable, and machine-readable format, preserving its characteristics or deliver it to another controller defined by the Data Subject.
              </p>
              <p class="mb-4">
                The portability of the Data Subject's data will not take place for inferred, derived, created, generated, or obtained information from the analysis or treatments carried out by Zwippetech.
              </p>
            </section>

            <!-- Revocation of Consent Section -->
            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Revocation of Consent</h3>
              <p class="mb-4">
                The Data Subject may revoke the authorization and consent granted to Zwippetech for the processing of their personal data by submitting a written request to the aforementioned email.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Modifications to the Privacy Policy</h3>
              <p class="mb-4">
                Zwippetech expressly reserves the right to modify, update, or supplement this Privacy Policy at any time. Any modification will be immediately communicated through the Platform.
              </p>
            </section>

            <section class="mb-12">
              <h3 class="text-2xl font-semibold mb-4">Applicable Legislation and Conflict Resolution</h3>
              <p class="mb-4">
                The terms of the Privacy Policy are governed and interpreted in accordance with the laws of the United States, subject to the jurisdiction of Delaware and the Competent Authorities for the Protection of Personal Data.
              </p>
            </section>

            <footer class="text-sm text-gray-600 border-t pt-8">
              <p>Copyright © 2025 Zwippetech, Inc. All rights reserved.</p>
            </footer>
          </div>
        </div>

        <div class="tab-panel hidden p-8" id="terms">
          <div class="prose max-w-none">
            <div set:html={policyHtml} />
          </div>
        </div>

        <div class="tab-panel hidden p-8" id="data">
          <div class="prose max-w-none">
            <div set:html={licenseHtml} />
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Remove active class from all buttons and panels
      tabButtons.forEach(btn => btn.classList.remove('active'));
      tabPanels.forEach(panel => panel.classList.add('hidden'));

      // Add active class to clicked button and show corresponding panel
      button.classList.add('active');
      const targetPanel = document.getElementById(button.dataset.target);
      targetPanel.classList.remove('hidden');
    });
  });

  // Función para manejar el botón de volver arriba
  document.addEventListener('DOMContentLoaded', () => {
    const scrollToTopButton = document.getElementById('scrollToTop');
    
    // Mostrar/ocultar el botón basado en la posición del scroll
    const toggleScrollButton = () => {
      if (window.scrollY > 500) {
        scrollToTopButton.classList.remove('opacity-0');
        scrollToTopButton.classList.add('opacity-100');
      } else {
        scrollToTopButton.classList.remove('opacity-100');
        scrollToTopButton.classList.add('opacity-0');
      }
    };
    
    // Función para volver arriba suavemente
    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    };
    
    // Event listeners
    window.addEventListener('scroll', toggleScrollButton);
    scrollToTopButton.addEventListener('click', scrollToTop);
  });
</script>

<style>
  .tab-button.active {
    @apply text-blue-600 border-blue-600;
  }
  .tab-panel {
    @apply p-4;
  }
  :global(.prose h1) {
    @apply text-3xl font-bold mb-6;
  }
  :global(.prose h2) {
    @apply text-2xl font-semibold mb-4 mt-8;
  }
  :global(.prose h3) {
    @apply text-xl font-semibold mb-3 mt-6;
  }
  :global(.prose p) {
    @apply mb-4 text-gray-600;
  }
  :global(.prose ul) {
    @apply list-disc pl-6 mb-4 space-y-2;
  }
  :global(.prose ol) {
    @apply list-decimal pl-6 mb-4 space-y-2;
  }
  :global(.prose table) {
    @apply min-w-full border border-gray-200 mb-4;
  }
  :global(.prose th) {
    @apply px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase bg-gray-50;
  }
  :global(.prose td) {
    @apply px-6 py-4 text-sm text-gray-900 border-t border-gray-200;
  }
</style> 