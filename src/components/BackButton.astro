---
const { href = "/" } = Astro.props;
---

<a 
  href={href}
  class="inline-flex items-center gap-3 px-5 py-2.5 bg-white hover:bg-gray-50 text-gray-700 
    hover:text-[#3983ED] rounded-xl shadow-sm border border-gray-200 hover:border-[#3983ED]/20 
    transition-all duration-300 absolute top-8 left-8 group"
>
  <div class="w-8 h-8 rounded-lg bg-gray-50 group-hover:bg-[#3983ED]/10 flex items-center 
    justify-center transition-colors duration-300">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      class="h-5 w-5 group-hover:text-[#3983ED]" 
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        stroke-width="2" 
        d="M10 19l-7-7m0 0l7-7m-7 7h18" 
      />
    </svg>
  </div>
  <span class="font-medium text-sm">Back to Home</span>
</a>

<style>
  a {
    text-decoration: none;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  
  a:hover svg {
    transform: translateX(-3px);
  }

  svg {
    transition: transform 0.2s ease;
  }

  a:active {
    transform: scale(0.98);
  }
</style> 