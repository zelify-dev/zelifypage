---
const currentPath = Astro.url.pathname;
const isSpanish = currentPath.startsWith('/es');

interface Props {
  links?: Array<{ label: string; href: string; }>;
}

// Definir tipos globales
declare global {
  interface Window {
    confetti: any;
    isSpanish: boolean;
  }
}

// Hacer isSpanish disponible globalmente
if (typeof window !== 'undefined') {
  window.isSpanish = isSpanish;
}
---

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link href="https://cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet">

<section class="relative text-white py-32 overflow-hidden card-section bg-gradient-to-b from-[#191919] to-[#1a1a1a]">
  <div class="absolute inset-0 bg-gradient w-full h-full opacity-50"></div>
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#505050]/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#505050]/10 rounded-full blur-3xl"></div>
  </div>
  <div class="spotlight"></div>
  <div class="mx-auto max-w-screen-lg px-4 sm:px-6 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <div class="w-full md:w-1/2 relative">
        <!-- Card Display -->
        <div class="relative w-full max-w-[300px] mx-auto">
          <img 
            src="/assets/img/cards/1.png" 
              alt="Zelify Card"
            class="w-full"
              id="cardImage"
            />
            
          <!-- Card Details Overlay -->
          <div class="absolute inset-0 flex flex-col justify-between p-6">
            <!-- Card Number -->
            <div class="mt-8">
              <div class="flex items-center justify-end space-x-2">
                <span id="cardNumberDisplay" class="font-mono text-base text-white tracking-wider">**** **** **** 4242</span>
                <button id="toggleNumber" class="text-white/80 hover:text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />

                  </svg>
                </button>
              </div>
            </div>

            <!-- Valid Thru & CVC -->
            <div class="flex justify-between items-end mt-auto">
              <div class="text-white">
                <div class="text-xs opacity-80">VALID THRU</div>
                <div class="font-mono">12/25</div>
              </div>
              <div class="text-white text-right">
                <div class="text-xs opacity-80">CVC</div>
                <div id="cvcDisplay" class="font-mono">***</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card Selectors -->
        <div class="mt-8">
          <div class="flex justify-center gap-2 sm:gap-4">
            <button 
              type="button"
              class="card-selector active"
              data-card="/assets/img/cards/1.png"
            >
              <img 
                src="/assets/img/cards/1.png"
                alt="Card 1"
                class="w-[60px] sm:w-[70px] h-auto rounded-lg"
                loading="lazy"
              />
            </button>
            <button 
              type="button"
              class="card-selector"
              data-card="/assets/img/cards/2.png"
            >
              <img 
                src="/assets/img/cards/2.png"
                alt="Card 2"
                class="w-[60px] sm:w-[70px] h-auto rounded-lg"
                loading="lazy"
              />
            </button>
            <button 
              type="button"
              class="card-selector"
              data-card="/assets/img/cards/3.png"
            >
              <img 
                src="/assets/img/cards/3.png"
                alt="Card 3"
                class="w-[60px] sm:w-[70px] h-auto rounded-lg"
                loading="lazy"
              />
            </button>
            <button 
              type="button"
              class="card-selector"
              data-card="/assets/img/cards/4.png"
            >
              <img 
                src="/assets/img/cards/4.png"
                alt="Card 4"
                class="w-[60px] sm:w-[70px] h-auto rounded-lg"
                loading="lazy"
              />
            </button>
            <button 
              type="button"
              class="card-selector"
              data-card="/assets/img/cards/5.png"
            >
              <img 
                src="/assets/img/cards/5.png"
                alt="Card 5"
                class="w-[60px] sm:w-[70px] h-auto rounded-lg"
                loading="lazy"
              />
            </button>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="w-full md:w-1/2 flex flex-col items-center space-y-8">
        <div class="text-center space-y-4">
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight">
            {isSpanish ? 'Elige tu tarjeta. Hazla tuya.' : 'Pick your card. Make it yours.'}
          </h2>
          <p class="text-base sm:text-lg text-gray-400 max-w-xl">
            {isSpanish ? 'Disfruta de la libertad de una tarjeta de debito fisica o virtual sin contacto que funciona en cualquier parte del mundo.' : 'Enjoy the freedom of a physical or virtual contactless debit card that works anywhere in the world.'}
          </p>
        </div>

        <div class="flex flex-col items-center gap-4 w-full max-w-[280px]">
        <button 
          id="toggleLock"
            class="w-full bg-gray-900 text-white rounded-xl py-2.5 px-5 
              flex items-center justify-center gap-3
            animate-pulse-strong hover:animate-none hover:scale-[1.02]
            border-2 border-transparent hover:border-white/20
            shadow-[0_0_15px_rgba(255,255,255,0.1)]
            hover:shadow-[0_0_30px_rgba(255,255,255,0.2)]
            transition-all duration-300"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <span class="text-white/90 text-sm">{isSpanish ? 'Bloquear tarjeta' : 'Lock card'}</span>
        </button>

          <button id="googlePay" class="w-full flex items-center justify-center gap-2 bg-white text-black px-5 py-2.5 rounded-lg hover:bg-gray-100 transition-all">
            <svg class="h-5 w-5" viewBox="0 0 48 48">
              <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
              <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
              <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
              <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
            </svg>
            <span class="flex-1 text-center text-sm">{isSpanish ? 'Conectar con Google Pay' : 'Connect with Google Pay'}</span>
          </button>

          <button id="applePay" class="w-full flex items-center justify-center gap-2 bg-black text-white px-5 py-2.5 rounded-lg border border-white/20 hover:bg-gray-900 transition-all">
            <svg class="h-5 w-5" viewBox="0 0 24 24">
              <path fill="currentColor" d="M17.5 12.5c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5-2.5-1.1-2.5-2.5zm-15 0c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5-2.5-1.1-2.5-2.5zm7.5-5c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5-2.5-1.1-2.5-2.5zm0 10c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5-2.5-1.1-2.5-2.5z"/>
            </svg>
            <span class="flex-1 text-center text-sm">{isSpanish ? 'Conectar con Apple Pay' : 'Connect with Apple Pay'}</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Wallet Connection Modal -->
<div id="modalOverlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 z-50">
  <div id="walletModal" class="fixed bottom-0 left-0 right-0 bg-gray-900 rounded-t-2xl p-6 transform translate-y-full transition-transform duration-300">
    <div class="text-center mb-6">
      <h3 id="walletTitle" class="text-2xl font-bold text-white mb-2"></h3>
      <p class="text-gray-400">{isSpanish ? 'Conecta tu tarjeta para usar con tu metodo de pago preferido' : 'Connect your card to use with your preferred payment method'}</p>
    </div>
    
    <div id="successMessage" class="hidden bg-green-500/20 text-green-400 p-4 rounded-lg mb-6">
      {isSpanish ? '¡Conectado exitosamente!' : 'Successfully connected!'}
    </div>
    
    <button
      id="connectButton"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-lg transition-all duration-300"
    >
      {isSpanish ? 'Conectar' : 'Connect'}
    </button>
  </div>
</div>

<!-- Success Modal -->
<div id="successModal" class="fixed inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 z-50">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="bg-gray-900 p-8 rounded-2xl shadow-xl transform scale-95 transition-all duration-300 relative z-10 max-w-md w-full mx-4">
    <div class="text-center">
      <div class="w-20 h-20 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <!-- User Info -->
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-gradient-to-r from-blue-500 to-green-500 flex items-center justify-center text-2xl font-bold text-white">
          <img 
            src={isSpanish ? "https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=200&auto=format" : "https://images.unsplash.com/photo-1618077360395-f3068be8e001?w=150&h=150&fit=crop"}
            alt={isSpanish ? "Juan Perez" : "John Cooper"}
            class="w-16 h-16 rounded-full object-cover"
          />
        </div>
        <div class="text-left">
          <h4 class="text-xl font-medium text-white">{isSpanish ? 'Juan Perez' : 'John Cooper'}</h4>
          <p class="text-gray-400">{isSpanish ? 'Cuenta Personal' : 'Personal Account'}</p>
        </div>
      </div>

      <!-- Transaction Details -->
      <div class="space-y-4">
        <div class="bg-gray-800/50 rounded-xl p-4">
          <div class="flex justify-between items-center mb-2">
            <span class="text-gray-400">{isSpanish ? 'Tarjeta terminada en' : 'Card ending in'}</span>
            <span class="font-mono text-white">4242</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-400">{isSpanish ? 'Conectado con' : 'Connected with'}</span>
            <span id="connectedService" class="text-white"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card-selector {
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.75rem;
    opacity: 0.5;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .card-selector.active {
    opacity: 1;
    background: rgba(255, 255, 255, 0.1);
    border-color: rgb(59, 130, 246);
  }

  .card-selector img {
    display: block;
  }

  .spotlight {
    position: absolute;
    height: 100%;
    width: 100%;
    pointer-events: none;
    background: radial-gradient(
      1200px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(80, 80, 80, 0.15),
      rgba(80, 80, 80, 0.15),
      transparent 50%
    );
    mix-blend-mode: screen;
    filter: blur(30px);
    opacity: 0.8;
    z-index: 2;
  }

  @media (max-width: 640px) {
    .card-container {
      transform: scale(0.9);
      margin: 0 auto;
      max-width: 100%;
    }
  }

  /* Actualizar el fondo con gradiente */
  .bg-gradient {
    background: linear-gradient(
      45deg,
      rgba(54, 124, 244, 0.05),
      rgba(25, 25, 25, 0.95),
      rgba(112, 250, 126, 0.05)
    );
    background-size: 400% 400%;
    animation: gradientBG 15s ease infinite;
    position: relative;
  }

  .card-section {
    background-color: transparent;
  }

  /* Segundo spotlight para más intensidad */
  .spotlight::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(80, 80, 80, 0.1),
      rgba(80, 80, 80, 0.1),
      transparent 50%
    );
    mix-blend-mode: screen;
    filter: blur(15px);
  }

  @keyframes textFloat {
    0% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
    100% { transform: translateY(0); }
  }

  .text-animate {
    animation: textFloat 4s ease-in-out infinite;
  }

  /* Animación al hacer scroll */
  @media (prefers-reduced-motion: no-preference) {
    .card-container {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s ease-out, transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    
    .card-container.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .text-animate {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s ease-out, transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .text-animate.visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fondo con gradiente animado */
  .bg-gradient {
    background: linear-gradient(
      45deg,
      rgba(54, 124, 244, 0.05),
      rgba(25, 25, 25, 0.95),
      rgba(112, 250, 126, 0.05)
    );
    background-size: 400% 400%;
    animation: gradientBG 15s ease infinite;
    position: relative;
  }

  .bg-gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    mix-blend-mode: overlay;
  }

  @keyframes gradientBG {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Efecto spotlight que sigue al cursor */
  .card-section {
    background-color: transparent;
  }

  /* Efecto de partículas sutiles */
  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-10px) translateX(5px); }
  }

  .card-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(2px 2px at 40px 60px, #fff 100%, transparent),
      radial-gradient(2px 2px at 20% 50%, #fff 100%, transparent),
      radial-gradient(2px 2px at 30% 100px, #fff 100%, transparent),
      radial-gradient(2px 2px at 40% 60%, #fff 100%, transparent),
      radial-gradient(2px 2px at 110px 90px, #fff 100%, transparent),
      radial-gradient(2px 2px at 80% 30%, #fff 100%, transparent);
    background-repeat: repeat;
    background-size: 200px 200px;
    opacity: 0.015;
    animation: float 8s ease-in-out infinite;
    pointer-events: none;
  }

  #toggleLock,
  #googlePay,
  #applePay {
    min-width: 280px;
    width: 100%;
    max-width: 320px;
  }

  /* Estilos para SweetAlert2 */
  .animated-popup {
    animation: popupScale 0.3s ease-out;
  }

  .swal-title {
    font-size: 2rem !important;
    margin-bottom: 1rem !important;
  }

  .swal-html {
    font-size: 1.1rem !important;
    line-height: 1.5 !important;
  }

  @keyframes popupScale {
    0% {
      transform: scale(0.9);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .metallic-card {
    position: relative;
    background-blend-mode: overlay;
    background-size: 200% 200%;
    filter: contrast(1.1) saturate(1.2);
  }
  
  .metallic-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      125deg,
      rgba(255,255,255,0.7) 0%,
      rgba(255,255,255,0.3) 25%,
      rgba(255,255,255,0.1) 50%,
      rgba(255,255,255,0.3) 75%,
      rgba(255,255,255,0.7) 100%
    );
    opacity: 0.4;
    animation: metalShine 3s linear infinite;
  }
  
  .metallic-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      45deg,
      transparent 0%,
      rgba(255, 255, 255, 0.4) 45%,
      rgba(255, 255, 255, 0.7) 50%,
      rgba(255, 255, 255, 0.4) 55%,
      transparent 100%
    );
    opacity: 0.6;
    animation: metalGlow 5s ease-in-out infinite;
  }

  @keyframes metalShine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  @keyframes metalGlow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.8; }
  }

  @media (max-width: 640px) {
    .card-container {
      transform: scale(0.9);
      margin: 0 auto;
      max-width: 100%;
    }
  }

  /* Mejora del rendimiento de las animaciones */
  @media (prefers-reduced-motion: no-preference) {
    .metallic-card {
      will-change: transform, filter;
    }
    
    .card-selector {
      will-change: transform;
    }
  }

  @keyframes pulse-strong {
    0%, 100% { 
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(255,255,255,0.7);
    }
    50% { 
      transform: scale(1.01);
      box-shadow: 0 0 0 10px rgba(255,255,255,0);
    }
  }

  .animate-pulse-strong {
    animation: pulse-strong 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes shine-fast {
    from {
      transform: translateX(-100%) skewX(15deg);
    }
    to {
      transform: translateX(200%) skewX(15deg);
    }
  }

  .animate-shine-fast {
    animation: shine-fast 1.5s ease-in-out infinite;
  }

  @keyframes pulse-vertical {
    0%, 100% { 
      transform: scaleY(2) translateY(-50%);
      opacity: 0.5;
    }
    50% { 
      transform: scaleY(2) translateY(50%);
      opacity: 0.2;
    }
  }

  /* Estilos para Swiper */
  .swiper {
    padding: 1rem 0;
  }

  .swiper-slide {
    width: auto;
    display: flex;
    justify-content: center;
  }

  .swiper-pagination {
    position: relative;
    margin-top: 1rem;
  }

  .swiper-pagination-bullet {
    background: rgba(255, 255, 255, 0.5);
  }

  .swiper-pagination-bullet-active {
    background: white;
  }

  .card-selector {
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.75rem;
    opacity: 0.5;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .card-selector.active {
    opacity: 1;
    background: rgba(255, 255, 255, 0.1);
    border-color: rgb(59, 130, 246);
  }

  .card-selector img {
    border-radius: 0.5rem;
    display: block;
  }

  @media (max-width: 640px) {
    .card-container {
      transform: scale(0.9);
      margin: 0 auto;
      max-width: 100%;
    }
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 2s linear infinite;
  }

  .confetti-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .confetti-piece {
    position: absolute;
    width: 8px;
    height: 8px;
    background-color: var(--confetti-color);
    border-radius: 50%;
    animation: confettiFall 1s ease-out forwards;
  }

  @keyframes confettiFall {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translateY(20px) rotate(360deg);
      opacity: 0;
    }
  }
</style>

<script define:vars={{ isSpanish }}>
  // Definir tipos para elementos del DOM
  const walletModal = document.getElementById('walletModal');
  const modalOverlay = document.getElementById('modalOverlay');
  const walletTitle = document.getElementById('walletTitle');
  const successModal = document.getElementById('successModal');
  const googlePay = document.getElementById('googlePay');
  const applePay = document.getElementById('applePay');
  const connectButton = document.getElementById('connectButton');
  const connectedService = document.getElementById('connectedService');

  // Manejar clics en los selectores de tarjeta
  document.querySelectorAll('.card-selector').forEach((selector) => {
    selector.addEventListener('click', () => {
      const cardImage = document.getElementById('cardImage');
      const newCardSrc = selector.getAttribute('data-card');
      
      if (cardImage instanceof HTMLImageElement && newCardSrc) {
        cardImage.src = newCardSrc;
      }

      // Actualizar el estado activo de los selectores
      document.querySelectorAll('.card-selector').forEach((btn) => {
        btn.classList.remove('active');
      });
      selector.classList.add('active');
    });
  });

  // Número real de la tarjeta
  const realCardNumber = '4242 4242 4242 4242';
  const realCVC = '123';
  let isNumberVisible = false;

  // Toggle número de tarjeta
  document.getElementById('toggleNumber')?.addEventListener('click', () => {
    isNumberVisible = !isNumberVisible;
    const cardNumberDisplay = document.getElementById('cardNumberDisplay');
    const cvcDisplay = document.getElementById('cvcDisplay');
    
    if (cardNumberDisplay) {
      cardNumberDisplay.textContent = isNumberVisible ? realCardNumber : '**** **** **** 4242';
    }
    if (cvcDisplay) {
      cvcDisplay.textContent = isNumberVisible ? realCVC : '•••';
    }
  });

  // Toggle bloqueo de tarjeta
  document.getElementById('toggleLock')?.addEventListener('click', () => {
    const cardImage = document.getElementById('cardImage');
    const toggleLock = document.getElementById('toggleLock');
    const isLocked = toggleLock?.classList.contains('locked');
    
    if (cardImage instanceof HTMLImageElement) {
      if (!isLocked) {
        cardImage.classList.add('grayscale', 'opacity-50');
        if (toggleLock) {
          toggleLock.classList.add('locked');
          toggleLock.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
            </svg>
            <span class="text-white/90">${isSpanish ? 'Desbloquear tarjeta' : 'Unlock card'}</span>
          `;
        }
      } else {
        cardImage.classList.remove('grayscale', 'opacity-50');
        if (toggleLock) {
          toggleLock.classList.remove('locked');
          toggleLock.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <span class="text-white/90">${isSpanish ? 'Bloquear tarjeta' : 'Lock card'}</span>
          `;
        }
      }
    }
  });

  // Event listeners para los botones de pago
  if (googlePay) {
    googlePay.addEventListener('click', () => showWalletModal('Google Pay'));
  }
  
  if (applePay) {
    applePay.addEventListener('click', () => showWalletModal('Apple Pay'));
  }

  if (modalOverlay) {
    modalOverlay.addEventListener('click', (e) => {
      if (e.target === modalOverlay) {
        hideWalletModal();
      }
    });
  }

  if (connectButton) {
    connectButton.addEventListener('click', handleConnect);
  }

  function showWalletModal(service) {
    if (!walletModal || !modalOverlay || !walletTitle || !connectButton) return;

    walletTitle.textContent = isSpanish ? 
      `Conectar con ${service}` : 
      `Connect with ${service}`;
    
    if (service === 'Apple Pay') {
      connectButton.classList.remove('bg-blue-600', 'hover:bg-blue-700');
      connectButton.classList.add('bg-black', 'hover:bg-gray-900');
    } else {
      connectButton.classList.remove('bg-black', 'hover:bg-gray-900');
      connectButton.classList.add('bg-blue-600', 'hover:bg-blue-700');
    }

    modalOverlay.classList.remove('opacity-0', 'pointer-events-none');
    walletModal.classList.remove('translate-y-full');
    document.body.style.overflow = 'hidden';
  }

  function hideWalletModal() {
    if (!walletModal || !modalOverlay || !connectButton) return;

    modalOverlay.classList.add('opacity-0', 'pointer-events-none');
    walletModal.classList.add('translate-y-full');
    document.body.style.overflow = 'auto';
    
    setTimeout(() => {
      if (connectButton) {
        connectButton.innerHTML = isSpanish ? 'Conectar' : 'Connect';
        connectButton.disabled = false;
        connectButton.classList.remove('bg-black', 'hover:bg-gray-900');
        connectButton.classList.add('bg-blue-600', 'hover:bg-blue-700');
      }
    }, 500);
  }

  function handleConnect() {
    if (!connectButton || !walletTitle) return;

    connectButton.innerHTML = `
      <div class="flex items-center justify-center gap-2">
        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>${isSpanish ? 'Conectando...' : 'Connecting...'}</span>
      </div>
    `;
    connectButton.disabled = true;

    setTimeout(() => {
      const currentService = walletTitle.textContent || '';
      
      if (modalOverlay && walletModal) {
        modalOverlay.classList.add('opacity-0', 'pointer-events-none');
        walletModal.classList.add('translate-y-full');
      }
      document.body.style.overflow = 'auto';

      if (successModal && connectedService) {
        const serviceName = currentService.replace(isSpanish ? 'Conectar con ' : 'Connect with ', '');
        connectedService.textContent = serviceName;
        
        successModal.style.display = 'flex';
        successModal.classList.remove('opacity-0', 'pointer-events-none');
        const bgEl = successModal.querySelector('.bg-gray-900');
        if (bgEl) {
          bgEl.classList.remove('scale-95');
        }

        window.confetti({
          particleCount: 200,
          spread: 90,
          origin: { y: 0.6 },
          colors: ['#4285F4', '#34A853', '#FBBC05', '#EA4335']
        });

        setTimeout(() => {
          window.confetti({
            particleCount: 150,
            spread: 60,
            origin: { y: 0.7 },
            colors: ['#4285F4', '#34A853', '#FBBC05', '#EA4335']
          });
        }, 250);

        setTimeout(() => {
          if (successModal) {
            successModal.classList.add('opacity-0', 'pointer-events-none');
            if (bgEl) {
              bgEl.classList.add('scale-95');
            }
            setTimeout(() => {
              if (successModal) {
                successModal.style.display = 'none';
              }
            }, 300);
          }
        }, 5000);
      }

      if (connectButton) {
        connectButton.innerHTML = isSpanish ? 'Conectar' : 'Connect';
        connectButton.disabled = false;
        connectButton.classList.remove('bg-black', 'hover:bg-gray-900');
        connectButton.classList.add('bg-blue-600', 'hover:bg-blue-700');
      }
    }, 1500);
  }
</script>

<script is:inline>
  // Función simple para lanzar confeti con los colores de Google
  function launchGoogleConfetti() {
    const colors = ['#4285F4', '#34A853', '#FBBC05', '#EA4335'];
    const defaults = { 
      colors: colors,
      origin: { y: 0.7 },
      particleCount: 100,
      spread: 70,
      ticks: 400,
      gravity: 1.2,
      scalar: 1.2,
      shapes: ['star', 'circle']
    };

    confetti(defaults);
  }

  // Hacer la función disponible globalmente
  window.launchGoogleConfetti = launchGoogleConfetti;
</script>

