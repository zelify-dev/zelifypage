---
import { t } from 'i18next';

export interface Props {
	links?: Array<{ label: string; href: string; }>;
}

// Definir los links directamente aquí
const links = [
	{
		label: "Home",
		href: "#home"
	},
	{
		label: "Cards",
		href: "#cards"
	},
	{
		label: "Features",
		href: "#features"
	},
	{
		label: "International",
		href: "#transfer"
	},
	{
		label: "Subscriptions",
		href: "#subscriptions"
	}
];
---

<header aria-label={t('components.header.aria-label')} id="home">
	<div class="mx-auto max-w-screen-lg py-4 px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-between">
			<div class="flex items-center gap-6">
				<a class="block text-white" href="/">
					<img
						class="h-10 w-auto"
						src="/assets/img/logo_white.png"
						alt={t('components.header.logoImageAlt')}
					/>
				</a>
				<nav aria-label="Site Nav" class="hidden md:block">
					<ul class="flex items-center gap-2 text-sm">
						{
							links.map((link) => (
								<li>
									<a
										class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-montserrat font-bold group"
										href={link.href}
									>
										<span class="relative z-10">{link.label}</span>
										<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>

			<div class="md:flex md:items-center md:gap-12">
				<a 
					href="/login" 
					class="inline-flex items-center justify-center px-4 py-2 border border-white text-white font-montserrat font-bold rounded-full hover:bg-white hover:text-blue-600 transition-all duration-300 text-sm gap-2"
				>
					<i class="eva eva-briefcase-outline"></i>
					Login for Banks
				</a>
			</div>
		</div>
	</div>
</header>

<style>
	a {
		box-sizing: border-box;
	}

	/* Animación suave para el hover */
	.group:hover .group-hover\:scale-100 {
		transform: scale(1);
	}

	.group {
		overflow: hidden;
	}
</style>
