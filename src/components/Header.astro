---
import { t } from 'i18next';

export interface Props {
	links?: Array<{ label: string; href: string; }>;
}

// Definir los links directamente aquí
const links = [
	{
		label: "Home",
		href: "#home"
	},
	{
		label: "Cards",
		href: "#cards"
	},
	{
		label: "Features",
		href: "#features"
	},
	{
		label: "International",
		href: "#transfer"
	},
	{
		label: "Subscriptions",
		href: "#subscriptions"
	}
];
---

<header class="relative z-50">
	<div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
		<div class="flex items-center gap-16">
			<a href="/" class="flex items-center gap-2">
				<img src="/assets/img/logo_white.png" alt="Zelify" class="h-8" />
			</a>

			<nav class="hidden md:flex items-center gap-8">
				<a 
					href="#home" 
					class="nav-item px-4 py-2 text-gray-50 font-medium"
				>
					Home
				</a>
				<a 
					href="#cards" 
					class="nav-item px-4 py-2 text-gray-50 font-medium"
				>
					Cards
				</a>
				<a 
					href="#features" 
					class="nav-item px-4 py-2 text-gray-50 font-medium"
				>
					Features
				</a>
				<a 
					href="#transfer" 
					class="nav-item px-4 py-2 text-gray-50 font-medium"
				>
					International
				</a>
				<a 
					href="#pricing" 
					onclick="document.getElementById('pricing').scrollIntoView({behavior: 'smooth'}); return false;"
					class="nav-item px-4 py-2 text-gray-50 font-medium"
				>
					Subscriptions
				</a>
			</nav>
		</div>

		<div class="flex items-center gap-4">
			<a
				href="/login"
				class="inline-flex items-center justify-center px-4 py-2 border border-white text-white font-medium rounded-full hover:bg-white hover:text-blue-600 transition-all duration-300 text-sm gap-2"
			>
				<i class="eva eva-log-in-outline text-lg"></i>
				Login for Banks
			</a>
		</div>
	</div>
</header>

<style>
	.nav-item {
		position: relative;
		transition: all 0.3s ease;
		border-radius: 9999px;
	}

	.nav-item:hover {
		background-color: rgba(255, 255, 255, 0.2);
	}

	.nav-item::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		width: 0;
		height: 2px;
		background-color: white;
		transition: all 0.3s ease;
		transform: translateX(-50%);
	}

	.nav-item:hover::after {
		width: 80%;
	}
</style>
