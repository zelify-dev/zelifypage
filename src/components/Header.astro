---
// @charset UTF-8
import { t } from 'i18next';

export interface Props {
	links?: Array<{ label: string; href: string; }>;
}

const currentPath = Astro.url.pathname;
const currentLang = currentPath.startsWith('/es') ? 'es' : 'en';
const alternateUrl = currentLang === 'es' ? currentPath.replace('/es', '') : `/es${currentPath}`;
---

<header class="relative z-50 mt-6">
	<div class="max-w-7xl mx-auto px-4 py-6 flex items-center justify-between">
		<div class="flex items-center gap-16">
			<a href={currentLang === 'es' ? '/es' : '/'} class="flex items-center gap-2">
				<img 
					src="/assets/logos/new_zelify_logo.svg" 
					alt="Zelify Logo" 
					class="h-8 w-auto"
					style="background: transparent;"
				/>
			</a>
			<nav class="hidden md:flex items-center gap-8">
				<a 
					href="#cards" 
					class="nav-item px-4 py-2 text-[#144092] font-medium"
				>
					{currentLang === 'es' ? 'Tarjetas' : 'Cards'}
				</a>
				<a 
					href="#features" 
					class="nav-item px-4 py-2 text-[#144092] font-medium"
				>
					{currentLang === 'es' ? 'Características' : 'Features'}
				</a>
				<a 
					href="#pricing" 
					onclick="document.getElementById('pricing').scrollIntoView({behavior: 'smooth'}); return false;"
					class="nav-item px-4 py-2 text-[#144092] font-medium"
				>
					{currentLang === 'es' ? 'Planes' : 'Plans'}
				</a>
			</nav>
		</div>

		<div class="flex items-center gap-4">
			<a
				href="https://business.zelify.com"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center justify-center px-4 py-2 bg-[#00223E] text-[#D8DCE2] font-medium rounded-[9px] hover:bg-[#001a2e] hover:scale-105 hover:shadow-lg transition-all duration-300 text-sm gap-2 transform"
			>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#B0FF51]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
				</svg>
				{currentLang === 'es' ? 'Para negocios' : 'For business'}
			</a>
			
			<a
				href={alternateUrl}
				class="inline-flex items-center justify-center px-3 py-1 bg-[#B0FF51] text-[#000000] font-medium rounded-[9px] hover:bg-[#9eea47] hover:scale-105 hover:shadow-lg hover:rotate-1 transition-all duration-300 text-sm border border-black transform"
			>
				{currentLang === 'es' ? 'EN' : 'ES'}
			</a>
		</div>
	</div>

</header>

<style>
	.nav-item {
		position: relative;
		transition: all 0.3s ease;
		border-radius: 9999px;
	}

	.nav-item:hover {
		background-color: rgba(255, 255, 255, 0.2);
	}
</style>
