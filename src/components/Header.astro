---
import { t } from 'i18next';

export interface Props {
	links?: Array<{ label: string; href: string; }>;
}

// Definir los links directamente aquí
const links = [
	{
		label: "Home",
		href: "#home"
	},
	{
		label: "Cards",
		href: "#cards"
	},
	{
		label: "Features",
		href: "#features"
	},
	{
		label: "International",
		href: "#transfer"
	},
	{
		label: "Subscriptions",
		href: "#subscriptions"
	}
];
---

<header class="relative z-50">
	<div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
		<div class="flex items-center gap-16">
			<a href="/" class="flex items-center gap-2">
				<img src="/assets/img/logo_white.png" alt="Zelify" class="h-8" />
			</a>

			<nav class="hidden md:flex items-center gap-8">
				<a 
					href="#home" 
					class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-medium group"
				>
					<span class="relative z-10">Home</span>
					<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
				</a>
				<a 
					href="#cards" 
					class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-medium group"
				>
					<span class="relative z-10">Cards</span>
					<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
				</a>
				<a 
					href="#features" 
					class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-medium group"
				>
					<span class="relative z-10">Features</span>
					<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
				</a>
				<a 
					href="#transfer" 
					class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-medium group"
				>
					<span class="relative z-10">International</span>
					<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
				</a>
				<a 
					href="#pricing" 
					onclick="document.getElementById('pricing').scrollIntoView({behavior: 'smooth'}); return false;"
					class="relative px-4 py-2 text-gray-50 transition-all duration-300 font-medium group"
				>
					<span class="relative z-10">Subscriptions</span>
					<span class="absolute inset-0 h-full w-full bg-white/20 rounded-full scale-0 transition-transform duration-300 ease-out group-hover:scale-110"></span>
				</a>
			</nav>
								</div>

		<div class="flex items-center gap-4">
			<a
				href="/login"
				class="inline-flex items-center justify-center px-4 py-2 border border-white text-white font-medium rounded-full hover:bg-white hover:text-blue-600 transition-all duration-300 text-sm gap-2"
			>
				<i class="eva eva-log-in-outline text-lg"></i>
				Login for Banks
			</a>
		</div>
	</div>
</header>

<style>
	a {
		box-sizing: border-box;
	}

	/* Animación suave para el hover */
	.group:hover .group-hover\:scale-100 {
		transform: scale(1);
	}

	.group {
		overflow: hidden;
	}
</style>
