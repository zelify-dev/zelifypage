---
import ChatPreview from './ChatPreview.astro';
import SocialPaymentUI from './SocialPaymentUI.tsx';
// import { t } from 'i18next'; // Eliminado porque no se usa

const currentPath = Astro.url.pathname;
const isSpanish = currentPath.startsWith('/es');
---

<div class="mx-auto max-w-screen-lg px-4 pt-8 pb-28 flex flex-col md:flex-row items-center justify-between bg-[#B0FF51]">
	<div class="text-center md:text-left md:w-1/2">
		<h1 class="hero-title mb-6">
			<span class={`lets-pay ${isSpanish ? 'text-3xl' : ''}`}>{isSpanish ? "Conectamos pagos, unimos" : "Let's pay"}</span>
			<span class={`social-text ${isSpanish ? 'text-8xl' : ''}`}>{isSpanish ? "personas" : "social"}</span>
		</h1>
		
		<p class="text-xl text-black max-w-2xl mb-8">
			{isSpanish ? 
				"Tienes el poder de " : 
				"You've got the power to "} 
			<strong>
				{isSpanish ? "conectar," : "connect,"}
			</strong>
			<br />
			<strong>
				{isSpanish ? "pagar" : "pay"}
			</strong> 
			{isSpanish ? "y" : "and"} 
			<strong>
				{isSpanish ? "compartir" : "share"}
			</strong> 
			<br class="md:hidden" />
			{isSpanish ? "instantáneamente" : "instantly"}
		</p>

		<div class="flex gap-4 justify-center md:justify-start">
			<button 
				id="openModal"
				class="group relative rounded-md px-5 py-2.5 text-sm font-medium text-white overflow-hidden
					bg-[#00223E] hover:bg-[#001a2e] transition-all duration-300
					border-2 border-transparent hover:border-white
					animate-pulse-strong hover:animate-none hover:scale-105
					shadow-[0_0_20px_rgba(255,255,255,0.2)]
					hover:shadow-[0_0_40px_rgba(255,255,255,0.5)]"
			>
				<!-- Efecto de destello -->
				<div class="absolute inset-0 opacity-0 group-hover:opacity-100">
					<div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent
						animate-shine-fast"></div>
					<!-- Segundo destello para más intensidad -->
					<div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent
						animate-shine-fast-delayed"></div>
					<div class="absolute inset-0 bg-gradient-to-b from-white/10 via-transparent to-white/10
						animate-pulse-vertical"></div>
				</div>
				
				<span class="flex items-center gap-2">
					<span class="relative z-10 group-hover:scale-110 transition-transform duration-200">
						{isSpanish ? "Obtener la app" : "Coming Soon"}
						<span class="absolute bottom-0 left-0 w-full h-0.5 bg-white scale-x-0 group-hover:scale-x-100
							transition-transform duration-300 origin-left"></span>
					</span>
					<span class="flex gap-1 text-base">
						<span class="appstore-icon">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:scale-125 transition-all duration-200 group-hover:rotate-12 text-[#B0FF51]" viewBox="0 0 24 24">
								<path fill="currentColor" d="M11.624 7.222c-.876 0-2.232-.996-3.66-.96-1.884.024-3.612 1.092-4.584 2.784-1.956 3.396-.504 8.412 1.404 11.172.936 1.344 2.04 2.856 3.504 2.808 1.404-.06 1.932-.912 3.636-.912 1.692 0 2.172.912 3.66.876 1.512-.024 2.472-1.368 3.396-2.724 1.068-1.56 1.512-3.072 1.536-3.156-.036-.012-2.94-1.128-2.976-4.488-.024-2.808 2.292-4.152 2.4-4.212-1.32-1.932-3.348-2.148-4.056-2.196-1.848-.144-3.396 1.008-4.26 1.008zm3.12-2.832c.78-.936 1.296-2.244 1.152-3.54-1.116.048-2.46.744-3.264 1.68-.72.828-1.344 2.16-1.176 3.432 1.236.096 2.508-.636 3.288-1.572z"/>
							</svg>
						</span>
						<span class="playstore-icon">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:scale-125 transition-all duration-200 group-hover:-rotate-12 text-[#B0FF51]" viewBox="0 0 512 512">
								<path fill="currentColor" d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/>
							</svg>
						</span>
					</span>
				</span>
			</button>
		</div>
	</div>

	<div class="md:w-1/2 mt-8 md:mt-0">
		<ChatPreview />
	</div>
</div>

<!-- Nueva sección "Money, Simplified" -->
<div class="w-full px-4 py-20 bg-gray-100">
	<div class="text-center max-w-4xl mx-auto">
		<p class="text-gray-600 text-sm mb-4">{isSpanish ? "Sin importar dónde te encuentres" : "No matter where you are"}</p>
		
		<h2 class="text-5xl mb-6">
			<span class="text-gray-800">{isSpanish ? "Dinero" : "Money"}</span>
			<span class="text-[#144092] font-bold"> {isSpanish ? "Simplificado" : "Simplified"}</span>
		</h2>
		
		<p class="text-xl text-gray-700 mb-4 font-bold">{isSpanish ? "Una forma más inteligente de mover dinero." : "A smarter way to move money."}</p>
		<br />
		<p class="text-gray-600 max-w-2xl mx-auto mb-8">
			{isSpanish ? (
				<>
					Ultra-rápido, encriptado y disponible en todas partes.<br />
					Envía y recibe fondos globalmente en solo segundos.
				</>
			) : (
				<>
					Lightning-fast, encrypted, and available everywhere.<br />
					Send and receive funds globally in just seconds.
				</>
			)}
		</p>
		
		<button class="bg-[#00223E] text-[#B0FF51] px-8 py-3 rounded-lg font-medium hover:bg-[#001a2e] transition-all duration-300 transform hover:scale-105">
			{isSpanish ? "Solicitar ahora" : "Apply now"}
		</button>
	</div>
</div>

<!-- Social Payment UI Section -->
<SocialPaymentUI client:load />

<style>
	:global(body) {
		background: #B0FF51;
		font-family: 'Nata Sans', sans-serif;
	}

	.hero-title {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
	}

	.lets-pay {
		color: black;
		font-size: 3.8rem;
		font-weight: 400;
		font-family: 'Nata Sans', sans-serif;
		line-height: 0.7;
		text-align: left;
		margin-left: 0;
		padding-left: 0;
	}

	.social-text {
		color: #144092;
		font-size: 9rem;
		font-weight: 800;
		font-family: 'Nata Sans', sans-serif;
		line-height: 0.7;
		margin-left: 0;
		position: relative;
		text-align: left;
	}

	/* Override para español */
	.lets-pay.text-3xl {
		font-size: 1.875rem !important;
		font-weight: 400 !important;
		line-height: 1.2 !important;
	}

	.social-text.text-8xl {
		font-size: 6rem !important;
		font-weight: 800 !important;
		line-height: 0.7 !important;
	}

	@keyframes shine {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}

	@keyframes gradient {
		0% {
			background-position: 0% 50%;
		}
		50% {
			background-position: 100% 50%;
		}
		100% {
			background-position: 0% 50%;
		}
	}

	@keyframes pulse-strong {
		0%, 100% { 
			transform: scale(1);
			box-shadow: 0 0 0 0 rgba(255,255,255,0.9);
		}
		50% { 
			transform: scale(1.02);
			box-shadow: 0 0 0 15px rgba(255,255,255,0);
		}
	}

	.animate-pulse-strong {
		animation: pulse-strong 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}

	@keyframes pulse-vertical {
		0%, 100% { transform: scaleY(2) translateY(-50%); opacity: 0.7; }
		50% { transform: scaleY(2) translateY(50%); opacity: 0.3; }
	}

	@keyframes shine {
		from {
			transform: translateX(-100%) skewX(15deg);
		}
		to {
			transform: translateX(300%) skewX(15deg);
		}
	}

	.animate-shine-fast {
		animation: shine 0.8s ease-in-out infinite;
		animation-delay: 0.5s;
	}

	.animate-shine-fast-delayed {
		animation: shine 0.8s ease-in-out infinite;
		animation-delay: 0.9s;
	}

	:global(html, body) {
		margin: 0;
		padding: 0;
		font-family: 'Nata Sans', sans-serif;
	}
</style>

<script>
window.addEventListener('DOMContentLoaded', () => {
	// Añadir animación aleatoria a los emojis
	const emojis = document.querySelectorAll('.emoji-content');
	emojis.forEach(emojiContainer => {
		const spans = emojiContainer.textContent?.split(' ') || [];
		emojiContainer.innerHTML = spans
			.map((emoji, index) => `<span style="--delay: ${index}">${emoji}</span>`)
			.join(' ');
	});

	// Modal functionality
	const modal = document.getElementById('qrModal');
	const modalContent = document.getElementById('modalContent');
	const openButton = document.getElementById('openModal');
	const closeButton = document.getElementById('closeModal');
	
	openButton?.addEventListener('click', () => {
		modal?.classList.remove('hidden');
		modal?.classList.add('flex');
		// Trigger animation
		setTimeout(() => {
			modalContent?.classList.remove('scale-95', 'opacity-0');
			modalContent?.classList.add('scale-100', 'opacity-100');
		}, 10);
	});
	
	closeButton?.addEventListener('click', () => {
		modalContent?.classList.remove('scale-100', 'opacity-100');
		modalContent?.classList.add('scale-95', 'opacity-0');
		setTimeout(() => {
			modal?.classList.remove('flex');
			modal?.classList.add('hidden');
		}, 300);
	});
	
	// Close modal when clicking outside
	modal?.addEventListener('click', (e) => {
		if (e.target === modal) {
			modalContent?.classList.remove('scale-100', 'opacity-100');
			modalContent?.classList.add('scale-95', 'opacity-0');
			setTimeout(() => {
				modal?.classList.remove('flex');
				modal?.classList.add('hidden');
			}, 300);
		}
	});


});
</script>

