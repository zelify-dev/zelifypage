---
export interface Props {
	label: string;
	type?: 'primary' | 'secondary';
	href?: string;
}

const { label, type = 'primary', href = '/' } = Astro.props;
---

{
	type === 'primary' ? (
		<a
			class="rounded-md bg-gray-950 hover:bg-transparent border-2 border-transparent hover:border-white transition-all px-5 py-2.5 text-sm font-medium text-white"
			href={href}
		>
			{label}
		</a>
	) : (
		<a
			class="rounded-md bg-transparent hover:bg-black border-2 border-gray-950 hover:border-transparent transition-all px-5 py-2.5 text-sm font-medium text-black"
			href={href}
		>
			{label}
		</a>
	)
}

<style>
	a:active {
		transform: scale(0.95);
	}
</style>
