---
import { t } from 'i18next';

const links = [
	{
		label: "Cards",
		href: "#cards"
	},
	{
		label: "Features",
		href: "#features"
	},
	{
		label: "International",
		href: "#transfer"
	},
	{
		label: "Plans",
		href: "#subscriptions"
	}
];
---

<footer class="bg-gray-900 text-white py-12">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-4 gap-y-12 gap-x-8 justify-items-center">
			<!-- Company Info -->
			<div class="text-center w-full max-w-xs">
				<img src="/assets/img/logo_white.png" alt="Zelify" class="h-8 mb-4 mx-auto" />
				<p class="text-gray-400">
					Transforming the way you handle international money transfers.
				</p>
			</div>

			<!-- Quick Links -->
			<div class="text-center w-full max-w-xs">
				<h3 class="text-xl font-bold mb-4">Quick Links</h3>
				<ul class="space-y-2">
					<li><a href="/" class="text-gray-400 hover:text-white">Get Paid Early</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">Fee-free Overdraft</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">Build Credit</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">50,000+ Fee-Free ATMs</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">High Yield Savings Account</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">Send and Receive Money</a></li>
					<li><a href="#" class="text-gray-400 hover:text-white">Security and Control</a></li>
				</ul>
			</div>

			<!-- Doc Center -->
			<div class="text-center w-full max-w-xs">
				<h3 class="text-xl font-bold mb-4">Zelify Docs</h3>
				<ul class="space-y-2">
					<li><a href="/doc-center#privacy" class="text-gray-400 hover:text-white">Privacy Policy</a></li>
					<li><a href="/doc-center#terms" class="text-gray-400 hover:text-white">Policy On The Prevention Of Money Laundering...</a></li>
					<li><a href="/doc-center#data" class="text-gray-400 hover:text-white">License Agreement</a></li>
				</ul>
			</div>

			<!-- Zwippetech Investors -->
			<div class="text-center w-full max-w-xs">
				<h3 class="text-xl font-bold mb-4">Zelify Investors</h3>
				<ul class="space-y-2">
					<li>
						<a 
							href="https://docsend.com/view/s/5mf9938tun8j2gsk" 
							target="_blank"
							rel="noopener noreferrer"
							class="text-gray-400 hover:text-white transition-colors duration-200 inline-flex items-center justify-center gap-2 mx-auto"
						>
							IR Investor Portal
							<svg 
								xmlns="http://www.w3.org/2000/svg" 
								class="h-4 w-4 opacity-75" 
								fill="none" 
								viewBox="0 0 24 24" 
								stroke="currentColor"
							>
								<path 
									stroke-linecap="round" 
									stroke-linejoin="round" 
									stroke-width="2" 
									d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" 
								/>
							</svg>
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="border-t border-gray-800 mt-12 pt-8 text-center">
			<p class="text-gray-400">&copy; 2025 Zelify. All rights reserved.</p>
		</div>
	</div>
</footer>

<div class="bg-gray-900 py-12 border-t border-gray-800">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-sm text-gray-400 space-y-6">
			<p class="leading-relaxed">
				<span class="font-medium font-bold">Zelify Platform  Terms & Conditions</span><br/><br/>
				Zwippetech, Inc. ("Zelify Platform") is a financial technology company and not a bank. Banking services are provided by our partner financial institutions, which are members of the Federal Deposit Insurance Corporation (FDIC) or other relevant regulatory bodies, depending on the jurisdiction. Deposit insurance applies to the failure of an insured bank, subject to the conditions set by the respective regulatory authorities. Pass-through deposit insurance coverage is available only when applicable regulatory requirements are met.
			</p>
			
			<p class="leading-relaxed">
				The Zelify Visa Debit Card and Zelify Mastercard Debit Card, as well as other financial products, are issued by our partner banks pursuant to licenses from Visa and Mastercard International. These cards may be used wherever Visa and Mastercard debit cards are accepted. Please refer to the back of your card for details on the issuing bank.
			</p>
			
			<p class="leading-relaxed">
				<span class="font-medium">Disclosures & Limitations of Liability</span><br/>
				The opinions, advice, services, and other information expressed or contributed by customers, users, or third parties do not necessarily reflect the views of Zwippetech, Inc. or our partner banks. Our partner banks are not responsible for the accuracy of any content provided by third parties.
			</p>
			
			<p class="leading-relaxed">
				Fees for ATM withdrawals and other transaction-related services may apply. Refer to the applicable deposit agreements and fee schedules for details, as terms vary by jurisdiction and financial institution.
			</p>
			
			<p class="leading-relaxed">
				Transactional fees and service charges are subject to change and depend on the terms of each respective account agreement and the regulatory framework of each operational market.
			</p>
			
			<p class="leading-relaxed">
				<span class="font-medium">Account Eligibility & Usage</span><br/>
				Subscription plans and purchases are subject to Zelify's User Terms and Conditions, available on our website.
			</p>
			
			<p class="leading-relaxed">
				To apply for a Zelify account, users must comply with all Know Your Customer (KYC) and Anti-Money Laundering (AML) protocols. Compliance requirements may vary by jurisdiction.
				Instant transfers may experience delays due to third-party processing times or regulatory requirements in certain markets.
			</p>
			
			<p class="leading-relaxed">
				<span class="font-medium">Interest & Savings Account Terms</span><br/>
				The Annual Percentage Yield (APY) for the Zelify Savings Account is variable and may change at any time, depending on the operational market and regulatory environment.
				No minimum balance is required; however, interest accrues only on balances starting at $0.01 or equivalent in local currency.
			</p>
			
			<p class="leading-relaxed">
				For further details regarding Zelify's financial products, services, and regulatory compliance, please visit our 
				<a href="/doc-center" class="text-blue-400 hover:text-blue-300 underline">resource section</a>
			</p>
			
			<p class="text-xs mt-8">© 2025 Zwippetech, Inc. All Rights Reserved.</p>
		</div>
	</div>
</div>
