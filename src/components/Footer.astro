---
import { t } from 'i18next';
---

<footer class="bg-gray-950 py-10">
	<div
		class="flex flex-col px-8 md:flex-row gap-20 justify-between items-center mx-auto max-w-screen-lg text-white"
	>
		<div class="w-3/3 md:w-1/3 flex gap-4 flex-col justify-center items-center">
			<img src="assets/img/logo.svg" alt="logo" class="w-1/2" />
			<p class="font-light">
				{t('footer.description')}
			</p>
		</div>
		<div class="w-3/3 md:w-1/3 flex-col hidden md:flex justify-center">
			<h3 class="font-bold text-xl">{t('footer.quickLinks')}</h3>
			<ul class="mt-4">
				<li class="mb-2 font-light"><a href="#home">Home</a></li>
				<li class="mb-2"><a href="#about">About</a></li>
				<li class="mb-2"><a href="#features">Features</a></li>
			</ul>
		</div>
	</div>
</footer>
