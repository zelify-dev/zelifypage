---
import { t } from 'i18next';

const links = [
	{
		label: "Home",
		href: "#home"
	},
	{
		label: "Cards",
		href: "#cards"
	},
	{
		label: "Features",
		href: "#features"
	},
	{
		label: "International",
		href: "#transfer"
	},
	{
		label: "Subscriptions",
		href: "#subscriptions"
	}
];
---

<footer class="bg-gray-900 text-white py-12">
	<div class="max-w-7xl mx-auto px-4">
		<div class="grid md:grid-cols-3 gap-12">
			<!-- Logo y descripción -->
			<div>
				<img src="/assets/img/logo_white.png" alt="Logo" class="h-8 mb-4" />
				<p class="text-gray-400 text-sm">
					{t('footer.description')}
				</p>
			</div>

			<!-- Quick Links -->
			<div>
				<h3 class="font-bold mb-4">{t('footer.quickLinks')}</h3>
				<ul class="space-y-2">
					{links.map(({ label, href }) => (
						<li>
							<a 
								href={href} 
								class="text-gray-400 hover:text-white transition-colors text-sm"
							>
								{label}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Social Links -->
			<div>
				<h3 class="font-bold mb-4">Follow Us</h3>
				<div class="flex gap-4">
					<a href="#" class="text-gray-400 hover:text-white transition-colors">
						<i class="eva eva-facebook-outline text-xl"></i>
					</a>
					<a href="#" class="text-gray-400 hover:text-white transition-colors">
						<i class="eva eva-twitter-outline text-xl"></i>
					</a>
					<a href="#" class="text-gray-400 hover:text-white transition-colors">
						<i class="eva eva-linkedin-outline text-xl"></i>
					</a>
					<a href="#" class="text-gray-400 hover:text-white transition-colors">
						<i class="eva eva-instagram-outline text-xl"></i>
					</a>
				</div>
			</div>
		</div>

		<div class="border-t border-gray-800 mt-12 pt-8 text-center text-gray-400 text-sm">
			© {new Date().getFullYear()} Zwippetech Inc. All rights reserved.
		</div>
	</div>
</footer>
