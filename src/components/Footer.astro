---
const isSpanish = Astro.url.pathname.startsWith('/es');

const links = [
	{
		label: isSpanish ? "Tarjetas" : "Cards",
		href: "#cards"
	},
	{
		label: isSpanish ? "Características" : "Features",
		href: "#features"
	},
	{
		label: isSpanish ? "Planes" : "Plans",
		href: "#subscriptions"
	}
];

const docCenterPath = isSpanish ? "/es/doc-center" : "/doc-center";
---

<footer class="text-white py-12" style="background-color: #00213C;">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex flex-col md:flex-row justify-center items-center gap-12">
			<!-- Company Info -->
			<div class="text-center">
				<div class="flex items-center justify-center mb-4">
					<img 
						src="/assets/logos/logo_dark_back.svg" 
						alt="Zelify Logo" 
						class="h-8 w-auto"
						style="background: transparent;"
					/>
				</div>
				<p class="text-gray-400">
					{isSpanish 
						? "Tienes el poder de conectar, pagar y compartir instantáneamente"
						: "Let's pay social"
					}
				</p>
			</div>

			<!-- Quick Links -->
			<div class="text-center">
				<h3 class="text-xl font-bold mb-4" style="color: #95FF0B;">{isSpanish ? "Enlaces Rápidos" : "Quick links"}</h3>
				<ul class="space-y-2">
					{links.map(({ label, href }) => (
						<li>
							<a href={href} class="text-gray-400 hover:text-white">{label}</a>
						</li>
					))}
					<li>
						<a href="/login" class="text-gray-400 hover:text-white">
							{isSpanish ? "Acceso banco asociado" : "Partner bank access"}
						</a>
					</li>
				</ul>
			</div>
		</div>
	</div>
</footer>

<div class="py-6 border-t border-gray-800" style="background-color: #00213C;">
	<div class="max-w-7xl mx-auto px-4">
		<p class="text-center text-gray-400 text-sm mb-3">
			{isSpanish 
				? "Zelify es una plataforma tecnológica actualmente en fase de desarrollo, aún no implementada ni operativa, y no proporciona ni procesa servicios financieros directamente; todas las operaciones financieras se realizan exclusivamente a través de socios regulados."
				: "Zelify is a technology platform currently in a development phase, not yet deployed or operational, and does not provide or process financial services directly; all financial operations are conducted exclusively through regulated third-party partners."
			}
		</p>
		{/* Copyright line */}
		<p class="text-center text-gray-400 text-sm">
			© {new Date().getFullYear()} Zelify. {isSpanish ? "Todos los derechos reservados." : "All rights reserved."}
		</p>
	</div>
</div>

<style>
	@media (max-width: 640px) {
		.text-sm {
			font-size: 0.8125rem;
		}
		
		.leading-relaxed {
			line-height: 1.6;
		}
	}
	
	@media (max-width: 480px) {
		.grid {
			gap-y: 8;
		}
		
		.space-y-6 > * + * {
			margin-top: 1.25rem;
		}
	}
</style>
