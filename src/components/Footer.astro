			<!-- Company Info -->
			<div class="text-center w-full max-w-xs">
				<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="120" height="60" viewBox="0 0 600 299.999988" preserveAspectRatio="xMidYMid meet" version="1.2" class="h-8 mb-4 mx-auto">
