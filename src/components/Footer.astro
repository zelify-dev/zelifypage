---
const isSpanish = Astro.url.pathname.startsWith('/es');

const links = [
	{
		label: isSpanish ? "Tarjetas" : "Cards",
		href: "#cards"
	},
	{
		label: isSpanish ? "Características" : "Features",
		href: "#features"
	},
	{
		label: isSpanish ? "Planes" : "Plans",
		href: "#subscriptions"
	}
];

const docCenterPath = isSpanish ? "/es/doc-center" : "/doc-center";
---

