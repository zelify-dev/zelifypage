---
import FeaturesComponent from './Features';
---

<!-- Eva Icons CSS -->
<link href="https://unpkg.com/eva-icons@1.1.3/style/eva-icons.css" rel="stylesheet">

<section class="relative py-32 bg-white flex items-center">
	<FeaturesComponent client:only="react" />
</section>

<style>
	/* Animaciones para los elementos */
	@keyframes float-slow {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(10px, -10px); }
	}

	@keyframes float-delayed {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-10px, -15px); }
	}

	@keyframes float-slow-2 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(15px, -5px); }
	}

	@keyframes float-delayed-2 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-5px, -10px); }
	}

	@keyframes float-slow-3 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(8px, -12px); }
	}

	@keyframes float-mini {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(5px, -5px) scale(1.1); }
	}

	@keyframes float-mini-2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(-5px, -8px) scale(1.1); }
	}

	@keyframes float-delayed-3 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-8px, -12px); }
	}

	@keyframes float-slow-4 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(12px, -8px); }
	}

	.animate-float-slow {
		animation: float-slow 6s ease-in-out infinite;
	}

	.animate-float-delayed {
		animation: float-delayed 8s ease-in-out infinite 1s;
	}

	.animate-float-slow-2 {
		animation: float-slow-2 7s ease-in-out infinite 2s;
	}

	.animate-float-delayed-2 {
		animation: float-delayed-2 9s ease-in-out infinite 1.5s;
	}

	.animate-float-slow-3 {
		animation: float-slow-3 8s ease-in-out infinite 3s;
	}

	.animate-float-mini {
		animation: float-mini 5s ease-in-out infinite;
	}

	.animate-float-mini-2 {
		animation: float-mini-2 6s ease-in-out infinite 2.5s;
	}

	.animate-float-delayed-3 {
		animation: float-delayed-3 7.5s ease-in-out infinite 2.5s;
	}

	.animate-float-slow-4 {
		animation: float-slow-4 8.5s ease-in-out infinite 1.5s;
	}

	.animate-pulse-slow {
		animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}

	@keyframes bounce-subtle {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-3px); }
	}

	.animate-bounce-subtle {
		animation: bounce-subtle 1s ease-in-out infinite;
	}

	:global(.feature-card) {
		@apply transition-all duration-500 hover:scale-105 hover:rotate-1;
	}

	:global(.feature-icon) {
		@apply transition-all duration-500;
	}

	:global(.feature-card:hover .feature-icon) {
		@apply transform rotate-12 scale-110;
	}

	/* Estilos para el botón activo */
	:global(.active-feature) {
		@apply border-[#3983ED] shadow-lg !important;
	}

	:global(.active-feature i) {
		@apply text-[#3983ED] !important;
	}

	:global(.active-feature h3) {
		@apply text-[#3983ED] !important;
	}

	/* Estilos para el hover */
	:global(.feature-button:hover) {
		@apply border-[#3983ED] shadow-lg;
	}

	:global(.feature-button:hover i) {
		@apply text-[#3983ED];
	}

	:global(.feature-button:hover h3) {
		@apply text-[#3983ED];
	}

	/* Nuevos estilos para el botón de retroceso */
	:global(.back-button) {
		@apply text-[#3983ED] p-2 hover:bg-gray-100 rounded-full transition-all;
	}

	:global(.back-button:hover) {
		@apply bg-gray-100;
	}

	:global(.back-button i) {
		@apply text-xl;
	}

	/* Estilo para el contenedor del slider */
	:global(.features-slider) {
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
	}
</style>
