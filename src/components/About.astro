---
import Card from './Card.astro';
import { t } from 'i18next';
---

<section
	id="about"
	class="flex flex-col items-center justify-center gap-16 mx-auto max-w-screen-lg relative z-0 px-4 m-16"
>
	<div class="flex flex-col gap-4 max-w-screen-sm">
		<h3 class="text-center text-3xl font-bold">{t('about.title')}</h3>
		<span class="text-center font-thin text-gray-700"
			>{t('about.description')}</span
		>
	</div>
	<div class="flex w-full justify-between gap-8">
		<img
			src="/assets/img/phone.png"
			alt="phone"
			class="hidden md:flex rounded-lg shadow-lg"
		/>
		<div class="flex flex-col gap-12">
			<Card
				title={t('about.card1.title')}
				description={t('about.card1.description')}
			/>
			<Card
				title={t('about.card2.title')}
				description={t('about.card2.description')}
			/>
			<Card
				title={t('about.card3.title')}
				description={t('about.card3.description')}
			/>
			<Card
				title={t('about.card4.title')}
				description={t('about.card4.description')}
			/>
			<Card
				title={t('about.card5.title')}
				description={t('about.card5.description')}
			/>
		</div>
	</div>
</section>

<style>
	img {
		max-width: 300px !important;
		height: auto;
		object-fit: cover;
	}
</style>
