---
import { t } from 'i18next';
---

<div class="relative">
  <div class="max-w-xs mx-auto bg-white rounded-t-3xl shadow-2xl overflow-hidden h-[calc(100vh-80px)] max-h-[650px] flex flex-col animate-fadeIn">
    <div class="py-2 px-4 bg-white border-b">
      <div class="flex items-center gap-3">
        <button class="text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <div class="flex items-center gap-2">
          <img 
            src="https://avatars.githubusercontent.com/u/20259832?s=400&u=0784b5671af390e2cd45b9c2251e4c858eaccb48&v=4" 
            alt="Joseph Cooper" 
            class="w-8 h-8 rounded-full object-cover border-2 border-gray-200"
          />
          <div>
            <h3 class="font-semibold text-gray-800 text-sm leading-tight">Joseph Cooper</h3>
            <p class="text-xs text-gray-500 leading-tight">@coop</p>
          </div>
        </div>
        <div class="flex gap-3 ml-auto">
          <div class="flex flex-col items-center">
            <button class="w-10 h-10 bg-green-500 rounded-full text-white hover:bg-green-600 transition-all transform hover:scale-105 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
              </svg>
            </button>
            <span class="text-xs text-gray-600 mt-1">Transfer</span>
          </div>
          <div class="flex flex-col items-center">
            <button class="w-10 h-10 bg-blue-500 rounded-full text-white hover:bg-blue-600 transition-all transform hover:scale-105 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13l-3 3m0 0l-3-3m3 3V8m0 13a9 9 0 110-18 9 9 0 010 18z" />
              </svg>
            </button>
            <span class="text-xs text-gray-600 mt-1">Request</span>
          </div>
        </div>
      </div>
    </div>

    <div class="px-4 flex-1 overflow-y-auto bg-gray-50" id="chat-container">
      <div class="space-y-3">
        <!-- Mensajes iniciales eliminados para que se generen dinámicamente -->
      </div>
    </div>

    <div class="py-3 px-4 bg-white border-t mt-auto">
      <div class="flex items-center gap-2">
        <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-full" id="emoji-button">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </button>
        <input 
          type="text" 
          id="message-input"
          placeholder="Type a message..." 
          class="flex-1 p-2 border rounded-full focus:outline-none focus:border-blue-500"
        />
        <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-full" id="send-button">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<div id="reactions-container" class="fixed pointer-events-none"></div>

<style>
  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.5);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100px) scale(1);
      opacity: 0;
    }
  }

  .reaction {
    position: absolute;
    animation: floatUp 1.5s ease-out forwards;
  }

  .chat-message {
    opacity: 0;
    transform: translateX(-20px);
    animation: slideInMessage 0.3s ease-out forwards;
    animation-delay: calc(var(--index, 0) * 100ms);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .social-icons-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 2rem;
    transform: rotate(-45deg);
    font-size: 2rem;
    opacity: 0.1;
    animation: slide 60s linear infinite;
  }

  .repeat-icon {
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes slide {
    from {
      transform: rotate(-45deg) translateY(-50%);
    }
    to {
      transform: rotate(-45deg) translateY(0%);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  .chat-message {
    animation: slideIn 0.3s ease-out forwards;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .typing-indicator {
    opacity: 1;
    animation: fadeIn 0.3s ease-out;
  }

  .animate-bounce {
    animation: bounce 0.6s infinite;
  }

  /* Ajustar tamaño de los mensajes */
  .chat-message .p-3 {
    padding: 0.5rem !important;
  }
  
  .chat-message .text-xl {
    font-size: 1rem !important;
  }
  
  .chat-message .text-sm {
    font-size: 0.8rem !important;
  }

  #chat-container {
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.2) transparent;
  }

  #chat-container::-webkit-scrollbar {
    width: 4px;
  }

  #chat-container::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-container::-webkit-scrollbar-thumb {
    background-color: rgba(0,0,0,0.2);
    border-radius: 20px;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fadeIn {
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .social-icons-bg {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 3rem;
    font-size: 1.5rem;
    transform: rotate(-15deg) scale(1.5);
  }

  .repeat-icon {
    opacity: 0.08;
    animation: float 3s ease-in-out infinite;
    animation-delay: calc(var(--delay, 0) * 200ms);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0);
    }
    50% {
      transform: translateY(-10px) rotate(5deg);
    }
  }

  @keyframes slideInMessage {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .bg-gradient {
    background: linear-gradient(-45deg, 
      rgba(59, 130, 246, 0.15),
      rgba(16, 185, 129, 0.15),
      rgba(99, 102, 241, 0.15),
      rgba(244, 114, 182, 0.15)
    );
    background-size: 400% 400%;
    animation: gradient 15s ease infinite;
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .floating-reactions {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .floating-reaction {
    position: absolute;
    opacity: 0.1;
    animation: floatUpBackground 8s linear infinite;
  }

  @keyframes floatUpBackground {
    0% {
      transform: translateY(100vh) scale(1);
      opacity: 0.1;
    }
    50% {
      opacity: 0.15;
    }
    100% {
      transform: translateY(-100px) scale(1.5);
      opacity: 0;
    }
  }
</style>

<script>
  const chatContainer = document.getElementById('chat-container');
  const messageContainer = chatContainer?.querySelector('.space-y-3');
  const reactionsContainer = document.getElementById('reactions-container');

  // Datos de ejemplo para simulación
  const mockMessages = [
    { text: "Hi! How's the project going? 👋", sender: "Joseph", type: "text" },
    { text: "Hey! All good, almost done 💪", sender: "Me", type: "text" },
    { text: "Hey, could you lend me some money for hosting? 🙏", sender: "Joseph", type: "text" },
    { amount: 250.00, sender: "Joseph", type: "request" },
    { text: "Sure, no problem! ✨", sender: "Me", type: "text" },
    { amount: 250.00, sender: "Me", type: "transfer" },
    { text: "Thanks! I'll pay you back on Friday 🙌", sender: "Joseph", type: "text" },
    { text: "Perfect! 👍", sender: "Me", type: "text" },
    { text: "By the way, wanna grab a coffee? ☕", sender: "Joseph", type: "text" },
    { text: "Sure! Let me send you some for the cookies too 🍪", sender: "Me", type: "text" },
    { amount: 100.00, sender: "Me", type: "transfer" },
    { text: "Great! See you in 30 🚗", sender: "Joseph", type: "text" }
  ];

  // Mensajes familiares para alternar
  const familyMessages = [
    { text: "Hi son! How was your day? 😊", sender: "Dad", type: "text" },
    { text: "Great dad! Everything good there? 🏠", sender: "Me", type: "text" },
    { text: "Yes, all good. Hey, can you help me with groceries? 🛒", sender: "Dad", type: "text" },
    { amount: 1500.00, sender: "Dad", type: "request" },
    { text: "Of course! I'll transfer it right now ❤️", sender: "Me", type: "text" },
    { amount: 1500.00, sender: "Me", type: "transfer" },
    { text: "Thanks son! You're the best 🙏✨", sender: "Dad", type: "text" },
    { text: "Coming for dinner on Sunday? 🍖", sender: "Dad", type: "text" },
    { text: "Sure! I'll be there 🚗", sender: "Me", type: "text" }
  ];

  // Función para agregar mensaje con animación
  function addMessage(amount: number, isSent: boolean = false) {
    const messageDiv = document.createElement('div');
    messageDiv.className = 'chat-message';
    const time = new Date().toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
    
    messageDiv.innerHTML = `
      <div class="flex flex-col ${isSent ? 'items-end' : 'items-start'}">
        <div class="p-3 rounded-2xl shadow-sm max-w-xs 
          ${isSent ? 'bg-[#3983ED]/10' : 'bg-white'} 
          transition-colors cursor-pointer">
          <p class="text-sm text-gray-500">${isSent ? 'You sent' : 'Joseph Cooper requests'}</p>
          <p class="text-xl font-semibold text-[#3983ED]">$${amount.toFixed(2)}</p>
          ${!isSent ? '<p class="text-sm text-gray-400">Tap to transfer</p>' : ''}
        </div>
        <span class="text-xs text-gray-400 mt-1 px-2">${time}</span>
      </div>
    `;

    messageContainer?.appendChild(messageDiv);
    chatContainer?.scrollTo(0, chatContainer.scrollHeight);
    return messageDiv;
  }

  // Función para mostrar el indicador de escritura
  function showTypingIndicator() {
    const typingDiv = document.createElement('div');
    typingDiv.className = 'chat-message typing-indicator';
    typingDiv.innerHTML = `
      <div class="flex items-end gap-2 justify-start">
        <div class="bg-gray-100 p-4 rounded-2xl shadow-sm">
          <div class="flex gap-1">
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </div>
        </div>
      </div>
    `;
    messageContainer?.appendChild(typingDiv);
    chatContainer?.scrollTo(0, chatContainer.scrollHeight);
    return typingDiv;
  }

  // Función para iniciar la simulación automática
  function startAutoChat() {
    let index = 0;
    let isShowingFamily = false;
    
    function sendNextMessage() {
      const currentMessages = isShowingFamily ? familyMessages : mockMessages;
      
      if (index < currentMessages.length) {
        const message = currentMessages[index];
        const typingIndicator = showTypingIndicator();
        
        setTimeout(() => {
          typingIndicator.remove();
          let messageDiv;
          
          if (message.type === 'text') {
            messageDiv = addTextMessage(message.text, message.sender);
          } else if (message.type === 'request') {
            messageDiv = addMessage(message.amount, false);
          } else if (message.type === 'transfer') {
            messageDiv = addMessage(message.amount, true);
          }
          
          if (messageDiv) {
            messageDiv.style.setProperty('--index', index.toString());
            index++;
            setTimeout(sendNextMessage, Math.random() * 1000 + 800);
          }
        }, Math.random() * 800 + 500);
      } else {
        // Reiniciar el ciclo alternando entre mensajes
        index = 0;
        isShowingFamily = !isShowingFamily;
        setTimeout(sendNextMessage, 1000);
      }
    }
    
    setTimeout(sendNextMessage, 500);
  }

  // Función para añadir mensaje de texto
  function addTextMessage(text: string, sender: string) {
    const messageDiv = document.createElement('div');
    messageDiv.className = 'chat-message';
    const time = new Date().toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
    
    const isMe = sender === 'Me';
    
    messageDiv.innerHTML = `
      <div class="flex flex-col ${isMe ? 'items-end' : 'items-start'}">
        <div class="p-3 rounded-2xl shadow-sm max-w-xs 
          ${isMe ? 'bg-[#3983ED] text-white' : 'bg-white'}
          transition-colors">
          <p>${text}</p>
        </div>
        <span class="text-xs text-gray-400 mt-1 px-2">${time}</span>
      </div>
    `;

    messageContainer?.appendChild(messageDiv);
    chatContainer?.scrollTo(0, chatContainer.scrollHeight);
    return messageDiv;
  }

  // Evento click para los mensajes y reacciones
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const message = target.closest('.chat-message');
    
    if (message) {
      const rect = message.getBoundingClientRect();
      for (let i = 0; i < 3; i++) {
        setTimeout(() => {
          createReaction(
            rect.left + Math.random() * rect.width,
            rect.top + Math.random() * rect.height
          );
        }, i * 100);
      }
    }
  });

  // Función para crear reacciones aleatorias
  function createReaction(x: number, y: number) {
    const reactions = ['❤️', '👍', '💙', '💫', '⭐️', '✨'];
    const reaction = document.createElement('span');
    reaction.className = 'reaction';
    reaction.textContent = reactions[Math.floor(Math.random() * reactions.length)];
    reaction.style.left = `${x}px`;
    reaction.style.top = `${y}px`;
    reactionsContainer.appendChild(reaction);

    // Eliminar el elemento después de la animación
    setTimeout(() => {
      reaction.remove();
    }, 1500);
  }

  // Añadir delays aleatorios a los iconos de fondo
  document.querySelectorAll('.repeat-icon').forEach((icon, index) => {
    icon.style.setProperty('--delay', index.toString());
  });

  // Iniciar el chat automático inmediatamente
  startAutoChat();
</script> 