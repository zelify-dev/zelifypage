---
const currentPath = Astro.url.pathname;
const isSpanish = currentPath.startsWith('/es');
---

<div class="relative">
  <div class="w-full max-w-md mx-auto">
    <div class="max-w-xs mx-auto bg-white rounded-t-3xl shadow-2xl overflow-hidden h-[calc(100vh-80px)] max-h-[650px] flex flex-col animate-fadeIn">
      <div class="py-2 px-4 bg-white border-b">
        <div class="flex items-center gap-3">
          <button class="text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <div class="flex items-center gap-2">
            <img 
              src={isSpanish ? "https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=200&auto=format" : "https://images.unsplash.com/photo-1618077360395-f3068be8e001?w=150&h=150&fit=crop"}
              alt={isSpanish ? "Juan Perez" : "John Cooper"}
              class="w-10 h-10 rounded-full object-cover"
            />
            <div>
              <h3 class="font-semibold text-gray-800 text-sm leading-tight">{isSpanish ? "Juan Perez" : "John Cooper"}</h3>
              <p class="text-xs text-gray-500 leading-tight">@{isSpanish ? "juanp" : "coop"}</p>
            </div>
          </div>
          <div class="flex gap-3 ml-auto">
            <div class="flex flex-col items-center">
              <button class="w-10 h-10 bg-green-500 rounded-full text-white hover:bg-green-600 transition-all transform hover:scale-105 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
                </svg>
              </button>
              <span class="text-xs text-gray-600 mt-1">{isSpanish ? "Transferir" : "Transfer"}</span>
            </div>
            <div class="flex flex-col items-center">
              <button class="w-10 h-10 bg-blue-500 rounded-full text-white hover:bg-blue-600 transition-all transform hover:scale-105 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13l-3 3m0 0l-3-3m3 3V8m0 13a9 9 0 110-18 9 9 0 010 18z" />
                </svg>
              </button>
              <span class="text-xs text-gray-600 mt-1">{isSpanish ? "Solicitar" : "Request"}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="px-4 flex-1 overflow-y-auto bg-gray-50" id="chat-container">
        <div class="space-y-3">
          <!-- Mensajes iniciales eliminados para que se generen dinámicamente -->
        </div>
      </div>

      <div class="py-3 px-4 bg-white border-t mt-auto">
        <div class="flex items-center gap-2">
          <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-full" id="emoji-button">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
          <input 
            type="text" 
            id="message-input"
            placeholder={isSpanish ? "Escribe un mensaje..." : "Type a message..."} 
            class="flex-1 p-2 border rounded-full focus:outline-none focus:border-blue-500"
          />
          <button class="p-2 text-gray-600 hover:bg-gray-100 rounded-full" id="send-button">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="reactions-container" class="fixed pointer-events-none"></div>

<style>
  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.5);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100px) scale(1);
      opacity: 0;
    }
  }

  .reaction {
    position: absolute;
    animation: floatUp 1.5s ease-out forwards;
  }

  .chat-message {
    opacity: 0;
    transform: translateX(-20px);
    animation: slideInMessage 0.3s ease-out forwards;
    animation-delay: calc(var(--index, 0) * 100ms);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .social-icons-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 2rem;
    transform: rotate(-45deg);
    font-size: 2rem;
    opacity: 0.1;
    animation: slide 60s linear infinite;
  }

  .repeat-icon {
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes slide {
    from {
      transform: rotate(-45deg) translateY(-50%);
    }
    to {
      transform: rotate(-45deg) translateY(0%);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  .chat-message {
    animation: slideIn 0.3s ease-out forwards;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .typing-indicator {
    opacity: 1;
    animation: fadeIn 0.3s ease-out;
  }

  .animate-bounce {
    animation: bounce 0.6s infinite;
  }

  /* Ajustar tamaño de los mensajes */
  .chat-message .p-3 {
    padding: 0.5rem !important;
  }
  
  .chat-message .text-xl {
    font-size: 1rem !important;
  }
  
  .chat-message .text-sm {
    font-size: 0.8rem !important;
  }

  #chat-container {
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.2) transparent;
  }

  #chat-container::-webkit-scrollbar {
    width: 4px;
  }

  #chat-container::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-container::-webkit-scrollbar-thumb {
    background-color: rgba(0,0,0,0.2);
    border-radius: 20px;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fadeIn {
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .social-icons-bg {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 3rem;
    font-size: 1.5rem;
    transform: rotate(-15deg) scale(1.5);
  }

  .repeat-icon {
    opacity: 0.08;
    animation: float 3s ease-in-out infinite;
    animation-delay: calc(var(--delay, 0) * 200ms);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0);
    }
    50% {
      transform: translateY(-10px) rotate(5deg);
    }
  }

  @keyframes slideInMessage {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .bg-gradient {
    background: linear-gradient(-45deg, 
      rgba(59, 130, 246, 0.15),
      rgba(16, 185, 129, 0.15),
      rgba(99, 102, 241, 0.15),
      rgba(244, 114, 182, 0.15)
    );
    background-size: 400% 400%;
    animation: gradient 15s ease infinite;
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .floating-reactions {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .floating-reaction {
    position: absolute;
    opacity: 0.1;
    animation: floatUpBackground 8s linear infinite;
  }

  @keyframes floatUpBackground {
    0% {
      transform: translateY(100vh) scale(1);
      opacity: 0.1;
    }
    50% {
      opacity: 0.15;
    }
    100% {
      transform: translateY(-100px) scale(1.5);
      opacity: 0;
    }
  }
</style>

<script>
  const currentPath = window.location.pathname;
  const isSpanish = currentPath.startsWith('/es');
  
  const chatContainer = document.getElementById('chat-container')?.querySelector('.space-y-3');
  const messageInput = document.getElementById('message-input');
  const sendButton = document.getElementById('send-button');
  const emojiButton = document.getElementById('emoji-button');
  const reactionsContainer = document.getElementById('reactions-container');

  // Mensajes predefinidos según el idioma
  const predefinedMessages = isSpanish ? [
    { text: "¡Hola Carlos! ¿Qué tal todo? 😊", sender: "other", time: "10:30" },
    { text: "¡Juan! Todo bien por aquí, ¿y tú? 🙌", sender: "user", time: "10:31" },
    { text: "Bien también. Oye, necesito pedirte un favor... 🙏", sender: "other", time: "10:31" },
    { text: "Claro, dime qué necesitas", sender: "user", time: "10:32" },
    { text: "¿Me podrías prestar $250 para pagar el hosting del proyecto? Me llegó la factura y ando corto este mes 😅", sender: "other", time: "10:33" },
    { text: "¡Por supuesto! No hay problema 👍", sender: "user", time: "10:33" },
    { text: "¡Eres un crack! Te lo devuelvo el viernes cuando me paguen 🙏", sender: "other", time: "10:34" },
    { text: "Tranquilo, sin prisa. Ahora mismo te hago la transferencia ✨", sender: "user", time: "10:35" },
    { text: "¡Muchísimas gracias! Me has salvado 🙌", sender: "other", time: "10:35" },
    { text: "¿Tomamos un café luego y me cuentas cómo va el proyecto? ☕", sender: "user", time: "10:36" },
    { text: "¡Perfecto! Te invito yo a las galletas 🍪", sender: "other", time: "10:36" },
    { text: "¡Genial! Nos vemos en media hora entonces 🚗", sender: "user", time: "10:37" }
  ] : [
    { text: "Hi! How's the project going? 👋", sender: "other", time: "10:30" },
    { text: "Hey! All good, almost done 💪", sender: "user", time: "10:31" },
    { text: "Hey, could you lend me some money for hosting? 🙏", sender: "other", time: "10:31" },
    { text: "Sure, how much do you need? 💭", sender: "user", time: "10:32" },
    { text: "About $250 if possible 🙌", sender: "other", time: "10:33" },
    { text: "No problem at all! ✨", sender: "user", time: "10:33" },
    { text: "You're the best! 🌟", sender: "other", time: "10:34" },
    { text: "I'll pay you back on Friday 💯", sender: "other", time: "10:35" },
    { text: "Take your time! 👍", sender: "user", time: "10:35" },
    { text: "Want to grab a coffee later? ☕", sender: "other", time: "10:36" },
    { text: "Sure! Let me send you some for the cookies too 🍪", sender: "user", time: "10:36" },
    { text: "You're awesome! See you in 30 🚗", sender: "other", time: "10:37" }
  ];

  // Función para crear un mensaje
  function createMessage(text: string, sender: string, time: string) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `chat-message flex ${sender === 'user' ? 'justify-end' : 'justify-start'}`;
    
    const innerDiv = document.createElement('div');
    innerDiv.className = `${sender === 'user' ? 'bg-blue-500 text-white' : 'bg-gray-200 text-gray-800'} rounded-2xl px-4 py-2 max-w-[80%]`;
    
    const textP = document.createElement('p');
    textP.className = 'text-sm';
    textP.textContent = text;
    
    const timeSpan = document.createElement('span');
    timeSpan.className = 'text-xs opacity-50 mt-1 block';
    timeSpan.textContent = time;
    
    innerDiv.appendChild(textP);
    innerDiv.appendChild(timeSpan);
    messageDiv.appendChild(innerDiv);
    
    return messageDiv;
  }

  // Función para mostrar el indicador de escritura
  function showTypingIndicator() {
    if (!chatContainer) return null;
    const typingDiv = document.createElement('div');
    typingDiv.className = 'chat-message flex justify-start';
    typingDiv.innerHTML = `
      <div class="bg-gray-200 rounded-2xl px-4 py-2">
        <div class="flex gap-2">
          <span class="w-2 h-2 bg-gray-500 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
          <span class="w-2 h-2 bg-gray-500 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
          <span class="w-2 h-2 bg-gray-500 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
        </div>
      </div>
    `;
    chatContainer.appendChild(typingDiv);
    return typingDiv;
  }

  // Función para manejar el scroll de manera suave
  function scrollToBottom() {
    if (!chatContainer) return;
    const parent = chatContainer.parentElement;
    if (!parent) return;

    const isScrolledToBottom = parent.scrollHeight - parent.clientHeight <= parent.scrollTop + 100;
    
    if (isScrolledToBottom) {
      parent.scrollTo({
        top: parent.scrollHeight,
        behavior: 'smooth'
      });
    }
  }

  // Función para agregar un mensaje con efecto de escritura
  async function addMessageWithTyping(text: string, sender: string, time: string) {
    if (!chatContainer) return;
    
    if (sender === 'other') {
      const typingIndicator = showTypingIndicator();
      scrollToBottom();
      await new Promise(resolve => setTimeout(resolve, 1500));
      typingIndicator?.remove();
    }
    
    const messageElement = createMessage(text, sender, time);
    chatContainer.appendChild(messageElement);
    scrollToBottom();
  }

  // Cargar mensajes predefinidos
  async function loadPredefinedMessages() {
    if (!chatContainer) return;
    chatContainer.innerHTML = '';
    
    for (let i = 0; i < predefinedMessages.length; i++) {
      const message = predefinedMessages[i];
      await new Promise(resolve => setTimeout(resolve, 1000));
      await addMessageWithTyping(message.text, message.sender, message.time);
    }
  }

  // Manejar el envío de mensajes
  async function handleSendMessage() {
    if (!messageInput || !(messageInput instanceof HTMLInputElement)) return;
    const text = messageInput.value.trim();
    if (!text) return;
    
    await addMessageWithTyping(text, 'user', getCurrentTime());
    messageInput.value = '';
    
    // Simular respuesta después de un breve retraso
    const response = isSpanish ? 
      "Perfecto! Procesare tu solicitud de inmediato" : 
      "Perfect! I'll process your request right away ✨";
    await addMessageWithTyping(response, 'other', getCurrentTime());
  }

  function getCurrentTime() {
    const now = new Date();
    return `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;
  }

  // Event listeners
  sendButton?.addEventListener('click', handleSendMessage);
  
  messageInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      handleSendMessage();
    }
  });

  // Cargar mensajes al inicio
  loadPredefinedMessages();

  // Manejar reacciones de emojis
  let isEmojiMenuOpen = false;
  const emojis = ['👍', '❤️', '😊', '🎉', '👏', '🙌'];

  function createEmojiMenu(x: number, y: number) {
    const menu = document.createElement('div');
    menu.className = 'absolute bg-white rounded-full shadow-lg p-2 flex gap-2 transform -translate-x-1/2 z-50';
    menu.style.left = `${x}px`;
    menu.style.top = `${y}px`;
    
    emojis.forEach(emoji => {
      const button = document.createElement('button');
      button.className = 'hover:scale-125 transition-transform';
      button.textContent = emoji;
      button.onclick = () => {
        addReaction(emoji, x, y);
        menu.remove();
        isEmojiMenuOpen = false;
      };
      menu.appendChild(button);
    });
    
    return menu;
  }

  function addReaction(emoji: string, x: number, y: number) {
    if (!reactionsContainer) return;
    
    const reaction = document.createElement('div');
    reaction.className = 'reaction absolute';
    reaction.textContent = emoji;
    reaction.style.left = `${x}px`;
    reaction.style.top = `${y}px`;
    
    reactionsContainer.appendChild(reaction);

    // Eliminar después de la animación
    setTimeout(() => reaction.remove(), 1500);
  }

  emojiButton?.addEventListener('click', () => {
    if (isEmojiMenuOpen) return;
    
    const rect = emojiButton.getBoundingClientRect();
    const menu = createEmojiMenu(rect.left + rect.width / 2, rect.top - 10);
    document.body.appendChild(menu);
    isEmojiMenuOpen = true;
    
    // Cerrar menú al hacer clic fuera
    const closeMenu = (e: MouseEvent) => {
      const target = e.target as Node;
      if (!menu.contains(target)) {
        menu.remove();
        isEmojiMenuOpen = false;
        document.removeEventListener('click', closeMenu);
      }
    };
    
    setTimeout(() => document.addEventListener('click', closeMenu), 0);
  });
</script> 